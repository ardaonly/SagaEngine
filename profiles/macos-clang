[settings]
os=Macos
os.version=12.0
arch=armv8
compiler=apple-clang
compiler.version=15
compiler.libcxx=libc++
compiler.cppstd=20
build_type=RelWithDebInfo

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
core.cache:storage_path=${profile_dir:../../cache/conan}

[options]
*:shared=False
*:fPIC=True

[buildenv]
CC=clang
CXX=clang++
SCCACHE_DIR=${profile_dir:../../cache/sccache}