[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=14
compiler.libcxx=libstdc++11
compiler.cppstd=gnu20
build_type=RelWithDebInfo

[conf]
tools.cmake.cmaketoolchain:generator=Ninja

[options]
*:shared=False
*:fPIC=True
&:with_sde=True

[buildenv]
CC=gcc
CXX=g++
SCCACHE_DIR=${profile_dir:../../cache/sccache}
