tar -tf build/dist/linux/Saga.tar.zst
python3 - <<'PY'
import json
from pathlib import Path

p = Path("build/reports/linux_distribution_smoke_report.json")
data = json.loads(p.read_text())

assert data.get("verified") is False

commands = data.get("commands", [])
by_label = {item.get("label"): item for item in commands}
for label in ["unpacked sagaproject help", "unpacked sagascript help", "unpacked sagapack help"]:
    item = by_label.get(label)
    assert item, f"missing command record: {label}"
    assert item.get("status") == "passed", f"tool help did not pass: {label}"

non_claims = json.dumps(data.get("nonClaims", []))
for needle in ["production", "enterprise", "verified final release"]:
    assert needle.lower() in non_claims.lower(), f"missing non-claim: {needle}"

print("Phase 36 packaged tool smoke evidence is present and non-overclaiming.")
PY
