python3 - <<'PY'
import json
from pathlib import Path

p = Path("build/reports/linux_distribution_smoke_report.json")
data = json.loads(p.read_text())

assert data.get("verified") is False
assert data.get("status") == "passed-with-limitations"

commands = json.dumps(data.get("commands", []))
for needle in ["sagaproject validate", "sagascript analyze", "workflow-smoke", "SagaRuntime", "SagaEditor"]:
    assert needle in commands, f"missing StarterArena dist command record: {needle}"

starter = data.get("starterArena", {})
assert starter.get("status") == "passed-with-limitations"

non_claims = json.dumps(data.get("nonClaims", []))
for needle in ["production", "enterprise", "verified final release", "full editor", "Visual Blocks", "gameplay readiness"]:
    assert needle.lower() in non_claims.lower(), f"missing non-claim: {needle}"

print("Phase 37 StarterArena distribution workflow evidence is present and non-overclaiming.")
PY
