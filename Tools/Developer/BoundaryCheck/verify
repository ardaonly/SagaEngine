#!/usr/bin/env bash
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
cd "$ROOT"

status=0

run_check() {
    echo
    echo "verify-quick: running: $*"
    "$@"
    local rc=$?
    if [[ $rc -ne 0 ]]; then
        echo "verify-quick: failed: $*"
        status=$rc
    fi
}

echo "verify: repository and module boundary checks"

run_check git diff --check
run_check python3 Tools/Licensing/regenerate_license_checksums.py --check
run_check python3 Tools/Licensing/verify_license_texts.py
run_check python3 Tools/Developer/BoundaryCheck/report_boundary_status.py --repo-root .
run_check python3 Tools/Developer/BoundaryCheck/check_public_private_boundary.py --repo-root .
run_check python3 Tools/Developer/BoundaryCheck/check_qt_boundary.py .
run_check python3 Tools/Developer/BoundaryCheck/check_engine_server_boundary.py --repo-root .

echo
if [[ $status -eq 0 ]]; then
    echo "verify-quick: passed"
else
    echo "verify-quick: failed"
fi

exit "$status"
