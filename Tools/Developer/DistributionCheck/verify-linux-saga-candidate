#!/usr/bin/env python3
"""Validate the Linux Saga distribution candidate evidence."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path
from typing import Any

from saga_linux_distribution_policy import (
    PACKAGE_NAME,
    PACKAGE_SCHEMA_VERSION,
    inventory_matches,
    validate_layout,
    validate_metadata_sets,
)


DEFAULT_LAYOUT = Path("build/dist/linux/Saga")
DEFAULT_ARCHIVE = Path("build/dist/linux/Saga.tar.zst")
DEFAULT_CHECKSUM = Path("build/dist/linux/Saga.sha256")
DEFAULT_PACKAGE_REPORT = Path("build/reports/linux_package_preflight_report.json")
DEFAULT_SMOKE_REPORT = Path("build/reports/linux_distribution_smoke_report.json")
DEFAULT_REPORT = Path("build/reports/linux_distributable_candidate_report.json")


def path_text(path: Path) -> str:
    return path.as_posix()


def add_check(
    checks: list[dict[str, Any]],
    *,
    label: str,
    status: str,
    required: bool = True,
    message: str | None = None,
    details: dict[str, Any] | None = None,
) -> bool:
    entry: dict[str, Any] = {
        "label": label,
        "status": status,
        "required": required,
    }
    if message:
        entry["message"] = message
    if details:
        entry["details"] = details
    checks.append(entry)
    return status == "passed" or not required


def add_artifact(
    artifacts: list[dict[str, Any]],
    *,
    label: str,
    path: Path,
    kind: str,
    required: bool = True,
) -> bool:
    available = path.exists()
    artifacts.append(
        {
            "label": label,
            "kind": kind,
            "path": path_text(path),
            "required": required,
            "status": "available" if available else ("blocked" if required else "missing"),
        }
    )
    return available or not required


def read_json(path: Path) -> tuple[dict[str, Any] | None, str | None]:
    try:
        return json.loads(path.read_text(encoding="utf-8")), None
    except FileNotFoundError:
        return None, f"missing JSON report: {path}"
    except json.JSONDecodeError as exc:
        return None, f"invalid JSON report {path}: {exc}"


def run_command(args: list[str], *, cwd: Path | None = None) -> dict[str, Any]:
    try:
        result = subprocess.run(
            args,
            cwd=cwd,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=60,
        )
        return {
            "args": args,
            "cwd": path_text(cwd) if cwd else None,
            "exitCode": result.returncode,
            "stdoutEvaluation": result.stdout[:2000],
            "stderrEvaluation": result.stderr[:2000],
            "status": "passed" if result.returncode == 0 else "blocked",
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "args": args,
            "cwd": path_text(cwd) if cwd else None,
            "status": "blocked",
            "message": "timed out after 60s",
            "stdoutEvaluation": (exc.stdout or "")[:2000],
            "stderrEvaluation": (exc.stderr or "")[:2000],
        }


def source_commit() -> str | None:
    result = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0:
        return None
    commit = result.stdout.strip()
    return commit or None


def command_status(report: dict[str, Any], label: str) -> str | None:
    for command in report.get("commands", []):
        if command.get("label") == label:
            return command.get("status")
    return None


def command_present(report: dict[str, Any], label: str) -> bool:
    return any(command.get("label") == label for command in report.get("commands", []))


def validate_package_report(
    package_report: dict[str, Any] | None,
    layout: Path,
    checks: list[dict[str, Any]],
    blockers: list[str],
) -> None:
    if package_report is None:
        add_check(checks, label="package report parsed", status="blocked", message="package report is unavailable")
        blockers.append("package report is unavailable")
        return

    schema_ok = package_report.get("schemaVersion") == PACKAGE_SCHEMA_VERSION
    add_check(
        checks,
        label="package report schema",
        status="passed" if schema_ok else "blocked",
        message=f"expected schemaVersion {PACKAGE_SCHEMA_VERSION}, got {package_report.get('schemaVersion')!r}" if not schema_ok else None,
    )
    identity_ok = package_report.get("packageName") == PACKAGE_NAME
    add_check(
        checks,
        label="package identity",
        status="passed" if identity_ok else "blocked",
        message=f"expected packageName {PACKAGE_NAME!r}" if not identity_ok else None,
    )
    metadata_errors = validate_metadata_sets(package_report)
    add_check(
        checks,
        label="package exact application, tool, and exclusion sets",
        status="passed" if not metadata_errors else "blocked",
        message="; ".join(metadata_errors) if metadata_errors else None,
    )
    inventory = package_report.get("stagedFiles")
    inventory_ok = isinstance(inventory, list) and inventory_matches(layout, inventory)
    add_check(
        checks,
        label="package staged file inventory",
        status="passed" if inventory_ok else "blocked",
        message="stagedFiles does not exactly match the current layout" if not inventory_ok else None,
    )

    add_check(
        checks,
        label="package report tool",
        status="passed" if package_report.get("tool") == "package-linux-saga" else "blocked",
        message=None if package_report.get("tool") == "package-linux-saga" else "package report tool is not package-linux-saga",
    )
    add_check(
        checks,
        label="package report verified flag",
        status="passed" if package_report.get("verified") is False else "blocked",
        message="package report must keep verified=false" if package_report.get("verified") is not False else None,
    )
    add_check(
        checks,
        label="package preflight status",
        status="passed" if package_report.get("status") == "preflight-passed" else "blocked",
        message=f"expected preflight-passed, got {package_report.get('status')!r}",
    )
    missing = package_report.get("missingInputs", [])
    add_check(
        checks,
        label="package missing inputs",
        status="passed" if missing == [] else "blocked",
        message="package report still lists missing inputs" if missing else None,
        details={"missingInputs": missing} if missing else None,
    )
    for label, field in [
        ("distribution layout available", "distributionLayoutStatus"),
        ("archive available", "archiveStatus"),
        ("checksum available", "checksumStatus"),
    ]:
        status = package_report.get(field, {}).get("status")
        add_check(
            checks,
            label=label,
            status="passed" if status == "available" else "blocked",
            message=f"expected {field}.status=available, got {status!r}",
        )

    for check in checks:
        if check.get("status") == "blocked" and str(check.get("label", "")).startswith(("package", "distribution", "archive", "checksum")):
            message = check.get("message") or check.get("label")
            blockers.append(str(message))


def validate_smoke_report(
    smoke_report: dict[str, Any] | None,
    checks: list[dict[str, Any]],
    blockers: list[str],
    known_limitations: list[str],
) -> None:
    if smoke_report is None:
        add_check(checks, label="smoke report parsed", status="blocked", message="smoke report is unavailable")
        blockers.append("smoke report is unavailable")
        return

    add_check(
        checks,
        label="smoke report tool",
        status="passed" if smoke_report.get("tool") == "smoke-linux-saga-dist" else "blocked",
        message=None if smoke_report.get("tool") == "smoke-linux-saga-dist" else "smoke report tool is not smoke-linux-saga-dist",
    )
    add_check(
        checks,
        label="smoke report verified flag",
        status="passed" if smoke_report.get("verified") is False else "blocked",
        message="smoke report must keep verified=false" if smoke_report.get("verified") is not False else None,
    )
    add_check(
        checks,
        label="distribution smoke status",
        status="passed" if smoke_report.get("status") == "passed-with-limitations" else "blocked",
        message=f"expected passed-with-limitations, got {smoke_report.get('status')!r}",
    )
    starter_status = smoke_report.get("starterArena", {}).get("status")
    add_check(
        checks,
        label="StarterArena workflow status",
        status="passed" if starter_status == "passed-with-limitations" else "blocked",
        message=f"expected StarterArena passed-with-limitations, got {starter_status!r}",
    )

    for label in [
        "StarterArena sagaproject validate",
        "StarterArena sagascript analyze",
        "StarterArena Saga workflow-smoke",
    ]:
        status = command_status(smoke_report, label)
        add_check(
            checks,
            label=f"{label} command",
            status="passed" if status == "passed" else "blocked",
            message=f"expected command status passed, got {status!r}",
        )

    for limitation in smoke_report.get("knownLimitations", []):
        if isinstance(limitation, str):
            known_limitations.append(limitation)

    for check in checks:
        if check.get("status") == "blocked" and str(check.get("label", "")).startswith(("smoke", "distribution", "StarterArena")) and check.get("required", True):
            message = check.get("message") or check.get("label")
            blockers.append(str(message))


def validate_artifacts(
    *,
    layout: Path,
    archive: Path,
    checksum: Path,
    checks: list[dict[str, Any]],
    artifacts: list[dict[str, Any]],
    commands: list[dict[str, Any]],
    blockers: list[str],
) -> None:
    add_artifact(artifacts, label="staged Linux layout", path=layout, kind="directory")
    add_artifact(artifacts, label="Linux package archive", path=archive, kind="archive")
    add_artifact(artifacts, label="Linux package checksum", path=checksum, kind="checksum")

    add_check(
        checks,
        label="staged Linux layout exists",
        status="passed" if layout.is_dir() else "blocked",
        message=f"missing layout: {layout}" if not layout.is_dir() else None,
    )
    if layout.is_dir():
        policy_errors = validate_layout(layout)
        add_check(
            checks,
            label="staged Linux layout whitelist",
            status="passed" if not policy_errors else "blocked",
            message="; ".join(policy_errors) if policy_errors else None,
        )
        blockers.extend(policy_errors)
    add_check(
        checks,
        label="archive exists",
        status="passed" if archive.is_file() and archive.stat().st_size > 0 else "blocked",
        message=f"missing or empty archive: {archive}" if not (archive.is_file() and archive.stat().st_size > 0) else None,
    )
    add_check(
        checks,
        label="checksum exists",
        status="passed" if checksum.is_file() and checksum.stat().st_size > 0 else "blocked",
        message=f"missing or empty checksum: {checksum}" if not (checksum.is_file() and checksum.stat().st_size > 0) else None,
    )

    if checksum.is_file():
        checksum_command = run_command(["sha256sum", "-c", checksum.name], cwd=checksum.parent)
        checksum_command["label"] = "candidate checksum verification"
        commands.append(checksum_command)
        add_check(
            checks,
            label="checksum verifies",
            status=checksum_command["status"],
            message="sha256sum -c failed" if checksum_command["status"] != "passed" else None,
        )
    else:
        blockers.append(f"missing checksum: {checksum}")

    if archive.is_file():
        tar_command = run_command(["tar", "-tf", str(archive)])
        tar_command["label"] = "candidate archive listing"
        commands.append(tar_command)
        entries = [line.strip() for line in str(tar_command.get("stdoutEvaluation", "")).splitlines() if line.strip()]
        root_ok = tar_command.get("status") == "passed" and bool(entries) and all(
            entry == "Saga/" or entry.startswith("Saga/") for entry in entries
        )
        add_check(
            checks,
            label="archive Saga/ root",
            status="passed" if root_ok else "blocked",
            message="archive root is not Saga/" if not root_ok else None,
            details={"entriesEvaluation": entries[:40]},
        )
    else:
        blockers.append(f"missing archive: {archive}")

    for check in checks:
        if check.get("status") == "blocked" and str(check.get("label", "")).startswith(("staged", "archive", "checksum")):
            message = check.get("message") or check.get("label")
            blockers.append(str(message))


def validate_non_claims(
    package_report: dict[str, Any] | None,
    smoke_report: dict[str, Any] | None,
    checks: list[dict[str, Any]],
) -> list[str]:
    non_claims = [
        "This candidate report does not claim production readiness; the package is not production-ready.",
        "This candidate report does not claim enterprise readiness; the package is not enterprise-ready.",
        "This candidate report does not claim a verified final release.",
        "This candidate report does not claim full distribution verification or certification.",
        "This candidate report does not claim full editor workflow.",
        "This candidate report does not claim full Visual Blocks UI.",
        "This candidate report does not claim full gameplay readiness.",
        "This candidate report does not claim full runtime validation.",
        "This candidate report does not claim cloud collaboration.",
        "This candidate report does not establish release readiness.",
    ]

    evidence_blob = json.dumps((package_report or {}).get("nonClaims", [])) + json.dumps((smoke_report or {}).get("nonClaims", []))
    for needle in [
        "production",
        "enterprise",
        "verified final release",
        "full distribution",
        "full editor",
        "Visual Blocks",
        "full gameplay",
    ]:
        add_check(
            checks,
            label=f"input non-claim: {needle}",
            status="passed" if needle.lower() in evidence_blob.lower() else "blocked",
            message=f"input reports do not include non-claim containing {needle!r}",
        )
    return non_claims


def write_report(report_out: Path, report: dict[str, Any]) -> None:
    report_out.parent.mkdir(parents=True, exist_ok=True)
    report_out.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--package-report", default=str(DEFAULT_PACKAGE_REPORT), help="Package preflight report path.")
    parser.add_argument("--smoke-report", default=str(DEFAULT_SMOKE_REPORT), help="Distribution smoke report path.")
    parser.add_argument("--archive", default=str(DEFAULT_ARCHIVE), help="Saga.tar.zst archive path.")
    parser.add_argument("--checksum", default=str(DEFAULT_CHECKSUM), help="Saga.sha256 checksum path.")
    parser.add_argument("--layout", default=str(DEFAULT_LAYOUT), help="Staged Saga layout path.")
    parser.add_argument("--report-out", default=str(DEFAULT_REPORT), help="Candidate report output path.")
    args = parser.parse_args()

    package_report_path = Path(args.package_report)
    smoke_report_path = Path(args.smoke_report)
    archive = Path(args.archive)
    checksum = Path(args.checksum)
    layout = Path(args.layout)
    report_out = Path(args.report_out)

    checks: list[dict[str, Any]] = []
    commands: list[dict[str, Any]] = []
    artifacts: list[dict[str, Any]] = []
    blockers: list[str] = []
    diagnostics: list[str] = []
    known_limitations: list[str] = [
        "This candidate gate collects package, archive, checksum, unpack smoke, and limited StarterArena workflow evidence only.",
        "Product Shell workflow evidence is no-UI and report-only.",
    ]

    add_artifact(artifacts, label="package preflight report", path=package_report_path, kind="json-report")
    add_artifact(artifacts, label="distribution smoke report", path=smoke_report_path, kind="json-report")

    package_report, package_error = read_json(package_report_path)
    smoke_report, smoke_error = read_json(smoke_report_path)
    if package_error:
        diagnostics.append(package_error)
        blockers.append(package_error)
    if smoke_error:
        diagnostics.append(smoke_error)
        blockers.append(smoke_error)
    if package_report is not None:
        for limitation in package_report.get("limitations", []):
            if isinstance(limitation, str):
                known_limitations.append(limitation)
    if package_report is not None and smoke_report is not None:
        identity_fields = ["packageName", "version", "gitCommit"]
        mismatches = [
            field
            for field in identity_fields
            if package_report.get(field) != smoke_report.get(field)
        ]
        add_check(
            checks,
            label="package and smoke identity",
            status="passed" if not mismatches else "blocked",
            message=f"package/smoke identity differs for: {mismatches}" if mismatches else None,
        )
        if mismatches:
            blockers.append(f"package/smoke identity differs for: {mismatches}")

    validate_artifacts(
        layout=layout,
        archive=archive,
        checksum=checksum,
        checks=checks,
        artifacts=artifacts,
        commands=commands,
        blockers=blockers,
    )
    validate_package_report(package_report, layout, checks, blockers)
    validate_smoke_report(smoke_report, checks, blockers, known_limitations)
    non_claims = validate_non_claims(package_report, smoke_report, checks)

    required_blocked = [check for check in checks if check.get("required", True) and check.get("status") == "blocked"]
    if required_blocked or blockers:
        status = "blocked"
        exit_code = 1
    else:
        status = "candidate-with-limitations"
        exit_code = 0

    report = {
        "schemaVersion": 2,
        "tool": "verify-linux-saga-candidate",
        "status": status,
        "verified": False,
        "sourceCommit": source_commit(),
        "packageName": package_report.get("packageName") if package_report else None,
        "version": package_report.get("version") if package_report else None,
        "gitCommit": package_report.get("gitCommit") if package_report else None,
        "layout": path_text(layout),
        "archive": path_text(archive),
        "checksum": path_text(checksum),
        "packageReport": path_text(package_report_path),
        "smokeReport": path_text(smoke_report_path),
        "candidateChecks": checks,
        "commands": commands,
        "artifacts": artifacts,
        "knownLimitations": known_limitations,
        "blockers": sorted(set(blockers)),
        "diagnostics": diagnostics,
        "nonClaims": non_claims,
    }
    write_report(report_out, report)

    print(f"verify-linux-saga-candidate: status={status}")
    print(f"verify-linux-saga-candidate: report={report_out}")
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
