{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/Build/${presetName}",
      "installDir": "${sourceDir}/Install/${presetName}",
      "toolchainFile": "${sourceDir}/Build/${presetName}/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Bin/$<CONFIG>",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Bin/$<CONFIG>",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Bin/$<CONFIG>",
        "CMAKE_C_COMPILER_LAUNCHER": "sccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "sccache",
        "SAGA_ENGINE_VERSION": "0.1.0",
        "SAGA_BUILD_REPRODUCIBLE": "ON",
        "SAGA_ENABLE_LTO": "OFF"
      },
      "environment": {
        "SCCACHE_DIR": "${sourceDir}/cache/sccache",
        "CONAN_USER_HOME": "${sourceDir}/cache/conan"
      }
    },
    {
      "name": "windows-msvc-14.38",
      "displayName": "Windows MSVC 14.38",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_C_FLAGS": "/Zc:__cplusplus /Zc:preprocessor /permissive-",
        "CMAKE_CXX_FLAGS": "/Zc:__cplusplus /Zc:preprocessor /permissive-",
        "SAGA_TOOLCHAIN_VERSION": "14.38"
      }
    },
    {
      "name": "linux-gcc-13",
      "displayName": "Linux GCC 13",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc-13",
        "CMAKE_CXX_COMPILER": "g++-13",
        "CMAKE_C_FLAGS": "-fdiagnostics-color=always",
        "CMAKE_CXX_FLAGS": "-fdiagnostics-color=always",
        "SAGA_TOOLCHAIN_VERSION": "13"
      }
    },
    {
      "name": "macos-clang-15",
      "displayName": "macOS AppleClang 15",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "SAGA_TOOLCHAIN_VERSION": "15"
      }
    },
    {
      "name": "shipping",
      "displayName": "Shipping Build",
      "inherits": "windows-msvc-14.38",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SAGA_ENABLE_PROFILING": "OFF",
        "SAGA_ENABLE_LTO": "ON",
        "SAGA_STRIP_SYMBOLS": "ON"
      }
    },
    {
      "name": "profile",
      "displayName": "Profile Build",
      "inherits": "windows-msvc-14.38",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SAGA_ENABLE_PROFILING": "ON",
        "SAGA_ENABLE_TRACING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-build",
      "configurePreset": "windows-msvc-14.38",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "shipping-build",
      "configurePreset": "shipping",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "default-test",
      "configurePreset": "windows-msvc-14.38",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "full-build",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-14.38"
        },
        {
          "type": "build",
          "name": "windows-msvc-build"
        },
        {
          "type": "test",
          "name": "default-test"
        }
      ]
    }
  ]
}