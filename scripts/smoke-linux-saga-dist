#!/usr/bin/env python3
"""Unpack and smoke-check the Linux Saga distribution archive."""

from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path


DEFAULT_ARCHIVE = Path("build/dist/linux/Saga.tar.zst")
DEFAULT_CHECKSUM = Path("build/dist/linux/Saga.sha256")
DEFAULT_WORK_DIR = Path("/tmp/saga_dist_smoke")
DEFAULT_REPORT = Path("build/reports/linux_distribution_smoke_report.json")


def path_text(path: Path) -> str:
    return path.as_posix()


def add_check(
    checks: list[dict[str, object]],
    *,
    label: str,
    path: Path,
    status: str,
    kind: str,
    message: str | None = None,
) -> None:
    item: dict[str, object] = {
        "label": label,
        "kind": kind,
        "path": path_text(path),
        "status": status,
    }
    if message:
        item["message"] = message
    checks.append(item)


def add_artifact(
    artifacts: list[dict[str, object]],
    *,
    label: str,
    path: Path,
    required: bool,
    kind: str,
) -> bool:
    exists = path.exists()
    artifacts.append(
        {
            "label": label,
            "kind": kind,
            "path": path_text(path),
            "required": required,
            "status": "available" if exists else ("blocked" if required else "missing"),
        }
    )
    return exists or not required


def run_command(
    commands: list[dict[str, object]],
    args: list[str],
    *,
    cwd: Path | None = None,
    required: bool,
    timeout: int = 10,
    label: str,
    expected_exit_codes: set[int] | None = None,
    limitation: str | None = None,
    optional_failure_status: str = "skipped",
) -> bool:
    expected = expected_exit_codes or {0}
    try:
        result = subprocess.run(
            args,
            cwd=cwd,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
        )
        status = "passed" if result.returncode in expected else ("blocked" if required else optional_failure_status)
        entry: dict[str, object] = {
            "label": label,
            "args": args,
            "cwd": path_text(cwd) if cwd else None,
            "exitCode": result.returncode,
            "required": required,
            "status": status,
            "stdoutPreview": result.stdout[:2000],
            "stderrPreview": result.stderr[:2000],
        }
        if limitation and status != "passed":
            entry["message"] = limitation
        commands.append(entry)
        return status == "passed" or (not required and optional_failure_status != "blocked")
    except subprocess.TimeoutExpired as exc:
        commands.append(
            {
                "label": label,
                "args": args,
                "cwd": path_text(cwd) if cwd else None,
                "required": required,
                "status": "blocked" if required else optional_failure_status,
                "message": f"timed out after {timeout}s",
                "stdoutPreview": (exc.stdout or "")[:2000],
                "stderrPreview": (exc.stderr or "")[:2000],
            }
        )
        return not required and optional_failure_status != "blocked"


def verify_archive_root(archive: Path) -> tuple[bool, list[str], str | None]:
    result = subprocess.run(
        ["tar", "-tf", str(archive)],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0:
        return False, [], result.stderr.strip() or "tar listing failed"
    entries = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    ok = bool(entries) and all(entry == "Saga/" or entry.startswith("Saga/") for entry in entries)
    return ok, entries, None if ok else "archive root is not Saga/"


def write_report(report_out: Path, report: dict[str, object]) -> None:
    report_out.parent.mkdir(parents=True, exist_ok=True)
    report_out.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def run_starter_arena_workflow(
    *,
    unpack_root: Path,
    work_dir: Path,
    commands: list[dict[str, object]],
    artifacts: list[dict[str, object]],
    diagnostics: list[str],
    known_limitations: list[str],
) -> dict[str, object]:
    project = unpack_root / "samples" / "StarterArena" / "StarterArena.sagaproj"
    scripts_dir = unpack_root / "samples" / "StarterArena" / "Scripts"
    validate_report = work_dir / "starter_arena_validate.json"
    sagascript_out = work_dir / "starter_arena_sagascript_analyze"
    product_report = work_dir / "starter_arena_product_shell_workflow_report.json"
    runtime_report = work_dir / "starter_arena_runtime_smoke.json"
    editor_report = work_dir / "starter_arena_editor_shell_report.json"

    starter_diagnostics: list[str] = []
    required_results: list[bool] = []

    required_results.append(
        run_command(
            commands,
            [
                str(unpack_root / "bin" / "sagaproject"),
                "validate",
                "--project",
                str(project),
                "--out",
                str(validate_report),
            ],
            required=True,
            label="StarterArena sagaproject validate",
            timeout=30,
        )
    )
    required_results.append(add_artifact(artifacts, label="StarterArena sagaproject validation report", path=validate_report, required=True, kind="json-report"))

    required_results.append(
        run_command(
            commands,
            [
                str(unpack_root / "bin" / "sagascript"),
                "analyze",
                "--source",
                str(scripts_dir),
                "--out",
                str(sagascript_out),
                "--json",
            ],
            required=True,
            label="StarterArena sagascript analyze",
            timeout=30,
        )
    )
    required_results.append(add_artifact(artifacts, label="StarterArena SagaScript analysis report", path=sagascript_out / "analysis_report.json", required=True, kind="json-report"))
    required_results.append(add_artifact(artifacts, label="StarterArena SagaScript diagnostics report", path=sagascript_out / "sagascript_diagnostics.json", required=True, kind="json-report"))

    required_results.append(
        run_command(
            commands,
            [
                str(unpack_root / "bin" / "Saga"),
                "--workflow-smoke",
                "--project",
                str(project),
                "--profile",
                "technical_preview",
                "--workflow-report-out",
                str(product_report),
            ],
            required=True,
            label="StarterArena Saga workflow-smoke",
            timeout=30,
        )
    )
    required_results.append(add_artifact(artifacts, label="StarterArena product shell workflow report", path=product_report, required=True, kind="json-report"))

    runtime_ok = run_command(
        commands,
        [
            str(unpack_root / "bin" / "SagaRuntime"),
            "--headless",
            "--project",
            str(project),
            "--starter-arena-smoke",
            "--smoke-report-out",
            str(runtime_report),
            "--smoke-frames",
            "30",
            "--fixed-dt",
            "0.016",
        ],
        required=False,
        label="StarterArena SagaRuntime packaged smoke",
        timeout=30,
        limitation=(
            "Packaged SagaRuntime StarterArena smoke is blocked in this distribution smoke; "
            "the current binary enters normal client startup, attempts UDP transport setup, and does not produce the requested smoke report."
        ),
        optional_failure_status="blocked",
    )
    add_artifact(artifacts, label="StarterArena runtime smoke report", path=runtime_report, required=False, kind="json-report")
    if not runtime_ok:
        message = "StarterArena SagaRuntime packaged smoke is blocked; no runtime smoke report was produced."
        starter_diagnostics.append(message)
        diagnostics.append(message)

    editor_ok = run_command(
        commands,
        [
            str(unpack_root / "bin" / "SagaEditor"),
            "--inspect-project",
            str(project),
            "--profile",
            "technical_preview",
            "--editor-shell-report",
            str(editor_report),
        ],
        required=False,
        label="StarterArena SagaEditor inspect-project",
        timeout=10,
        limitation="Packaged SagaEditor inspect smoke is blocked: SagaEditor reports unknown argument '--inspect-project'.",
        optional_failure_status="blocked",
    )
    add_artifact(artifacts, label="StarterArena editor shell report", path=editor_report, required=False, kind="json-report")
    if not editor_ok:
        message = "StarterArena SagaEditor inspect-project is blocked; SagaEditor reports unknown argument '--inspect-project'."
        starter_diagnostics.append(message)
        diagnostics.append(message)

    report_only_message = (
        "StarterArena product shell workflow output is report-only; referenced developer-tree commands inside that report "
        "are not executed by this distribution smoke."
    )
    starter_diagnostics.append(report_only_message)
    known_limitations.append(report_only_message)
    known_limitations.append("Phase 37 does not execute Visual Blocks workflow commands.")

    status = "passed-with-limitations" if all(required_results) else "blocked"
    return {
        "project": path_text(project),
        "status": status,
        "requiredCommands": [
            "StarterArena sagaproject validate",
            "StarterArena sagascript analyze",
            "StarterArena Saga workflow-smoke",
        ],
        "blockedCommands": [
            "StarterArena SagaRuntime packaged smoke",
            "StarterArena SagaEditor inspect-project",
        ],
        "diagnostics": starter_diagnostics,
        "nonClaims": [
            "StarterArena workflow smoke does not claim full gameplay readiness.",
            "StarterArena workflow smoke does not claim full editor workflow.",
            "StarterArena workflow smoke does not claim full Visual Blocks UI.",
            "StarterArena workflow smoke does not claim production readiness.",
            "StarterArena workflow smoke does not claim enterprise readiness.",
            "StarterArena workflow smoke does not claim a verified final release.",
        ],
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--archive", default=str(DEFAULT_ARCHIVE), help="Saga.tar.zst archive path.")
    parser.add_argument("--checksum", default=str(DEFAULT_CHECKSUM), help="Saga.sha256 checksum path.")
    parser.add_argument("--work-dir", default=str(DEFAULT_WORK_DIR), help="Temporary unpack work directory.")
    parser.add_argument("--report-out", default=str(DEFAULT_REPORT), help="Smoke report output path.")
    args = parser.parse_args()

    archive = Path(args.archive)
    checksum = Path(args.checksum)
    work_dir = Path(args.work_dir)
    report_out = Path(args.report_out)
    unpack_root = work_dir / "Saga"

    checks: list[dict[str, object]] = []
    commands: list[dict[str, object]] = []
    artifacts: list[dict[str, object]] = []
    diagnostics: list[str] = []
    known_limitations = [
        "This smoke verifies archive checksum, unpack, file presence, executable bits, and limited help commands only.",
        "This smoke does not claim production readiness.",
        "This smoke does not claim enterprise readiness.",
        "This smoke does not claim a verified final release.",
        "This smoke does not claim full distribution verification.",
        "This smoke does not claim full editor workflow.",
        "This smoke does not claim full Visual Blocks UI.",
        "This smoke does not claim full gameplay readiness.",
        "This smoke does not claim cloud collaboration.",
        "sagaproject, sagascript, and sagapack checks are limited to packaged help output from the unpacked distribution.",
        "SagaEditor does not currently expose a --help smoke path in the unpacked distribution.",
    ]
    non_claims = [
        "This report does not claim production readiness; the distribution is not production-ready.",
        "This report does not claim enterprise readiness; the distribution is not enterprise-ready.",
        "This report does not claim a verified final release.",
        "This report does not claim full distribution verification.",
        "This report does not claim full editor workflow.",
        "This report does not claim full Visual Blocks UI.",
        "This report does not claim full gameplay readiness.",
        "This report does not claim cloud collaboration.",
        "This report does not mark any phase Verified.",
    ]

    add_check(checks, label="archive file", path=archive, status="passed" if archive.is_file() else "blocked", kind="file")
    add_check(checks, label="checksum file", path=checksum, status="passed" if checksum.is_file() else "blocked", kind="file")

    if not archive.is_file() or not checksum.is_file():
        diagnostics.append("archive or checksum file is missing")
        report = {
            "schemaVersion": 1,
            "tool": "smoke-linux-saga-dist",
            "status": "blocked",
            "verified": False,
            "archive": path_text(archive),
            "checksum": path_text(checksum),
            "unpackRoot": path_text(unpack_root),
            "checks": checks,
            "commands": commands,
            "artifacts": artifacts,
            "diagnostics": diagnostics,
            "knownLimitations": known_limitations,
            "nonClaims": non_claims,
        }
        write_report(report_out, report)
        return 1

    checksum_ok = run_command(
        commands,
        ["sha256sum", "-c", checksum.name],
        cwd=checksum.parent,
        required=True,
        label="checksum verification",
    )
    if not checksum_ok:
        diagnostics.append("checksum verification failed")

    root_ok, archive_entries, root_error = verify_archive_root(archive)
    add_check(
        checks,
        label="archive Saga/ root",
        path=archive,
        status="passed" if root_ok else "blocked",
        kind="archive",
        message=root_error,
    )
    if not root_ok:
        diagnostics.append(root_error or "archive root validation failed")

    if work_dir.exists():
        shutil.rmtree(work_dir)
    work_dir.mkdir(parents=True, exist_ok=True)

    unpack_ok = False
    if checksum_ok and root_ok:
        unpack_ok = run_command(
            commands,
            ["tar", "-xf", str(archive), "-C", str(work_dir)],
            required=True,
            timeout=60,
            label="archive unpack",
        )
        if not unpack_ok:
            diagnostics.append("archive unpack failed")
    else:
        diagnostics.append("archive unpack skipped because checksum or archive root validation failed")

    add_check(
        checks,
        label="unpacked Saga root",
        path=unpack_root,
        status="passed" if unpack_root.is_dir() else "blocked",
        kind="directory",
    )

    required_files = [
        "BUILD_INFO.json",
        "VERSION",
        "VERIFY.txt",
        "KNOWN_LIMITATIONS.md",
        "bin/Saga",
        "bin/SagaEditor",
        "bin/SagaRuntime",
        "bin/SagaServer",
        "bin/sagaproject",
        "bin/sagascript",
        "bin/sagapack",
        "bin/sde",
        "tools/sagaproject",
        "tools/sagascript",
        "tools/sagapack",
        "tools/sde",
    ]
    required_dirs = [
        "samples/StarterArena",
        "docs/product",
        "licenses",
    ]
    executables = {
        "bin/Saga",
        "bin/SagaEditor",
        "bin/SagaRuntime",
        "bin/SagaServer",
        "bin/sagaproject",
        "bin/sagascript",
        "bin/sagapack",
        "bin/sde",
        "tools/sagaproject",
        "tools/sagascript",
        "tools/sagapack",
        "tools/sde",
    }
    for rel in required_files:
        path = unpack_root / rel
        ok = path.is_file() and (rel not in executables or path.stat().st_size > 0 and path.exists() and path_text(path) and path.is_file() and path.stat().st_mode & 0o111)
        add_check(checks, label=f"unpacked {rel}", path=Path("Saga") / rel, status="passed" if ok else "blocked", kind="executable" if rel in executables else "file")
        if not ok:
            diagnostics.append(f"required unpacked file/executable missing: Saga/{rel}")
    for rel in required_dirs:
        path = unpack_root / rel
        ok = path.is_dir()
        add_check(checks, label=f"unpacked {rel}", path=Path("Saga") / rel, status="passed" if ok else "blocked", kind="directory")
        if not ok:
            diagnostics.append(f"required unpacked directory missing: Saga/{rel}")

    if unpack_root.is_dir():
        run_command(commands, [str(unpack_root / "bin" / "sde"), "--help"], required=True, label="unpacked sde help")
        run_command(commands, [str(unpack_root / "bin" / "Saga"), "--help"], required=True, label="unpacked Saga help")
        run_command(commands, [str(unpack_root / "bin" / "SagaRuntime"), "--help"], required=True, label="unpacked SagaRuntime help")
        run_command(commands, [str(unpack_root / "bin" / "SagaServer"), "--help"], required=True, label="unpacked SagaServer help")
        run_command(
            commands,
            [str(unpack_root / "bin" / "SagaEditor"), "--help"],
            required=False,
            label="unpacked SagaEditor help",
            limitation="SagaEditor does not currently expose a --help smoke path.",
        )
        for tool in ["sagaproject", "sagascript", "sagapack"]:
            tool_ok = run_command(
                commands,
                [str(unpack_root / "bin" / tool), "--help"],
                required=True,
                label=f"unpacked {tool} help",
            )
            if not tool_ok:
                diagnostics.append(f"unpacked {tool} help failed from the packaged distribution")

    starter_arena: dict[str, object] = {
        "status": "skipped",
        "diagnostics": ["StarterArena workflow smoke skipped because archive unpack did not produce a Saga root."],
    }
    if unpack_root.is_dir():
        starter_arena = run_starter_arena_workflow(
            unpack_root=unpack_root,
            work_dir=work_dir,
            commands=commands,
            artifacts=artifacts,
            diagnostics=diagnostics,
            known_limitations=known_limitations,
        )

    blocked_checks = [item for item in checks if item.get("status") == "blocked"]
    blocked_required_commands = [
        item for item in commands if item.get("required") is True and item.get("status") == "blocked"
    ]
    blocked_required_artifacts = [
        item for item in artifacts if item.get("required") is True and item.get("status") == "blocked"
    ]
    limitation_commands = [
        item for item in commands if item.get("required") is False and item.get("status") != "passed"
    ]

    status = "blocked" if blocked_checks or blocked_required_commands or blocked_required_artifacts or starter_arena.get("status") == "blocked" else "passed-with-limitations"
    if status == "blocked":
        exit_code = 1
    else:
        exit_code = 0

    report = {
        "schemaVersion": 1,
        "tool": "smoke-linux-saga-dist",
        "status": status,
        "verified": False,
        "archive": path_text(archive),
        "checksum": path_text(checksum),
        "unpackRoot": path_text(unpack_root),
        "archiveEntriesPreview": archive_entries[:80],
        "checks": checks,
        "commands": commands,
        "artifacts": artifacts,
        "starterArena": starter_arena,
        "diagnostics": diagnostics,
        "knownLimitations": known_limitations,
        "nonClaims": non_claims,
    }
    if limitation_commands:
        report["limitations"] = limitation_commands

    write_report(report_out, report)

    print(f"smoke-linux-saga-dist: status={status}")
    print(f"smoke-linux-saga-dist: archive={archive}")
    print(f"smoke-linux-saga-dist: unpack_root={unpack_root}")
    print(f"smoke-linux-saga-dist: report={report_out}")
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
