#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

profile="linux-gcc"
preset="linux-gcc"
version="$(tr -d '[:space:]' < VERSION 2>/dev/null || printf '0.0.0')"
build_dir="build/RelWithDebInfo-${version}"
target=""
run_build=false

usage() {
    cat <<'USAGE'
Usage:
  scripts/build-default [options]

Options:
  --run                 Execute the canonical build commands.
  --dry-run             Print the canonical build commands without running them.
  --profile <name>      Forge/Conan profile. Default: linux-gcc.
  --preset <name>       CMake preset. Default: linux-gcc.
  --build-dir <path>    Build directory. Default: build/RelWithDebInfo-<VERSION>.
  --target <name>       Optional CMake target to build.
  -h, --help            Show this help.

Default behavior is dry-run. This script does not run tests, package outputs, or
distribution staging.
USAGE
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --run)
            run_build=true
            shift
            ;;
        --dry-run)
            run_build=false
            shift
            ;;
        --profile)
            profile="${2:?--profile requires a value}"
            shift 2
            ;;
        --preset)
            preset="${2:?--preset requires a value}"
            shift 2
            ;;
        --build-dir)
            build_dir="${2:?--build-dir requires a value}"
            shift 2
            ;;
        --target)
            target="${2:?--target requires a value}"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "build-default: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ ! -x Tools/Forge/bin/forge ]]; then
    echo "build-default: missing executable Tools/Forge/bin/forge" >&2
    exit 1
fi

commands=(
    "Tools/Forge/bin/forge nix install --profile ${profile}"
    "Tools/Forge/bin/forge nix configure --preset ${preset}"
    "Tools/Forge/bin/forge nix build --build ${build_dir}${target:+ --target ${target}}"
)

echo "build-default: canonical build baseline"
echo "build-default: profile=${profile}"
echo "build-default: preset=${preset}"
echo "build-default: build_dir=${build_dir}"
if [[ -n "$target" ]]; then
    echo "build-default: target=${target}"
else
    echo "build-default: target=<default>"
fi

if [[ "$run_build" != true ]]; then
    echo "build-default: dry-run only; no build was executed"
    for command in "${commands[@]}"; do
        echo "+ ${command}"
    done
    exit 0
fi

echo "build-default: executing canonical build commands"
Tools/Forge/bin/forge nix install --profile "$profile"
Tools/Forge/bin/forge nix configure --preset "$preset"
build_args=(nix build --build "$build_dir")
if [[ -n "$target" ]]; then
    build_args+=(--target "$target")
fi
Tools/Forge/bin/forge "${build_args[@]}"
