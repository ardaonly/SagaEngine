#!/usr/bin/env python3
"""Linux Saga distribution layout staging and preflight.

This script stages the first Linux layout from real existing inputs, then fails
honestly when required binaries, docs, samples, archive, or checksum entries are
missing. It does not create the final archive or checksum.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path.cwd()
DEFAULT_OUTPUT = Path("build/dist/linux/Saga")
DEFAULT_REPORT = Path("build/reports/linux_package_preflight_report.json")


def read_version() -> str:
    version_file = Path("VERSION")
    if not version_file.exists():
        return "0.0.0"
    return version_file.read_text(encoding="utf-8").strip()


def default_build_dirs(config: str) -> list[Path]:
    version = read_version()
    candidates = [
        Path(f"build/RelWithDebInfo-{version}-sde"),
        Path(f"build/RelWithDebInfo-{version}"),
        Path(f"build/{config}-{version}-sde"),
        Path(f"build/{config}-{version}"),
        Path("build/RelWithDebInfo"),
        Path("build"),
    ]
    return candidates


def first_existing(paths: list[Path]) -> Path | None:
    for path in paths:
        if path.exists():
            return path
    return None


def is_executable(path: Path) -> bool:
    return path.is_file() and path.stat().st_size > 0 and os.access(path, os.X_OK)


def path_text(path: Path) -> str:
    return path.as_posix()


def record_check(
    *,
    label: str,
    kind: str,
    category: str,
    paths: list[Path],
    available: bool,
    required_inputs: list[dict[str, object]],
    available_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
    resolved_path: Path | None = None,
    message: str | None = None,
) -> None:
    record: dict[str, object] = {
        "label": label,
        "kind": kind,
        "category": category,
        "paths": [path_text(path) for path in paths],
        "status": "available" if available else "missing",
    }
    if resolved_path is not None:
        record["resolvedPath"] = path_text(resolved_path)
    if message is not None:
        record["message"] = message

    required_inputs.append(record)
    if available:
        available_inputs.append(record)
    else:
        missing_inputs.append(record)


def check_file(
    label: str,
    path: Path,
    missing: list[str],
    required_inputs: list[dict[str, object]],
    available_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
    *,
    category: str,
) -> None:
    available = path.is_file()
    message = None if available else f"{label}: missing file {path}"
    if message is not None:
        missing.append(message)
    record_check(
        label=label,
        kind="file",
        category=category,
        paths=[path],
        available=available,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=path if available else None,
        message=message,
    )


def check_dir(
    label: str,
    path: Path,
    missing: list[str],
    required_inputs: list[dict[str, object]],
    available_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
    *,
    category: str,
) -> None:
    available = path.is_dir()
    message = None if available else f"{label}: missing directory {path}"
    if message is not None:
        missing.append(message)
    record_check(
        label=label,
        kind="directory",
        category=category,
        paths=[path],
        available=available,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=path if available else None,
        message=message,
    )


def check_binary(
    label: str,
    candidates: list[Path],
    missing: list[str],
    required_inputs: list[dict[str, object]],
    available_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
    *,
    category: str,
) -> None:
    existing = first_existing(candidates)
    available = existing is not None and is_executable(existing)
    message = None
    if not available:
        joined = ", ".join(path.as_posix() for path in candidates)
        message = f"{label}: missing real executable; checked {joined}"
        missing.append(message)
    record_check(
        label=label,
        kind="executable",
        category=category,
        paths=candidates,
        available=available,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=existing if available else None,
        message=message,
    )


def status_for_label(required_inputs: list[dict[str, object]], label: str) -> str:
    for item in required_inputs:
        if item.get("label") == label:
            return str(item.get("status"))
    return "unknown"


def write_report(report_path: Path, report: dict[str, object]) -> None:
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def resolved_input(available_inputs: list[dict[str, object]], label: str) -> Path:
    for item in available_inputs:
        if item.get("label") == label and item.get("resolvedPath"):
            return Path(str(item["resolvedPath"]))
    raise RuntimeError(f"internal error: missing resolved input for {label}")


def git_commit() -> str | None:
    result = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    if result.returncode != 0:
        return None
    commit = result.stdout.strip()
    return commit or None


def copy_file(source: Path, destination: Path, staged_inputs: list[dict[str, object]], label: str) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, destination)
    staged_inputs.append(
        {
            "label": label,
            "kind": "file",
            "source": path_text(source),
            "destination": path_text(destination),
        }
    )


def copy_tree(source: Path, destination: Path, staged_inputs: list[dict[str, object]], label: str) -> None:
    if destination.exists():
        shutil.rmtree(destination)
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(source, destination)
    staged_inputs.append(
        {
            "label": label,
            "kind": "directory",
            "source": path_text(source),
            "destination": path_text(destination),
        }
    )


def verification_text(*, without_server: bool) -> str:
    server_check = "" if without_server else "test -x bin/SagaServer\n"
    return f"""# Saga Linux Layout Verification

This file describes presence checks for the staged layout only. Passing these
commands does not prove package readiness, distribution readiness, workflow
correctness, archive integrity, or maintainer verification.

Run from the staged layout root:

```bash
test -f VERSION
test -f KNOWN_LIMITATIONS.md
python3 -m json.tool BUILD_INFO.json
test -x bin/Saga
test -x bin/SagaEditor
test -x bin/SagaRuntime
{server_check}test -x tools/sagaproject
test -x tools/sagapack
test -x tools/sagascript
test -x tools/sde
test -d samples/StarterArena
test -f docs/README.md
test -d licenses
```

Archive and checksum checks are intentionally absent from this staged layout.
`Saga.tar.zst` and `Saga.sha256` remain separate package blockers until a later
phase creates them honestly.
"""


def known_limitations_text() -> str:
    return """# Saga Linux Layout Known Limitations

This staged layout is not a final distribution.

- Not production-ready.
- Not package-ready until archive and checksum gates pass.
- Not distribution-ready until the final distribution gate passes.
- No full editor UI is claimed.
- No Visual Blocks editor UI is claimed.
- No enterprise collaboration is claimed.
- No cloud workspace is claimed.
- No package readiness is claimed unless `scripts/package-linux-saga` passes all required checks.
- Runtime, editor, server, and tool workflows are not proven beyond real input existence checks.
- `Saga.tar.zst` is not created by Phase 33.
- `Saga.sha256` is not created by Phase 33.
- No phase is marked Verified by this staged layout.
"""


def stage_layout(
    *,
    output: Path,
    build_dir: Path,
    available_inputs: list[dict[str, object]],
    without_server: bool,
) -> dict[str, object]:
    staged_inputs: list[dict[str, object]] = []

    if output.exists():
        shutil.rmtree(output)
    output.mkdir(parents=True, exist_ok=True)

    binaries = [
        ("Saga product shell", "Saga"),
        ("SagaEditor shell", "SagaEditor"),
        ("SagaRuntime executable", "SagaRuntime"),
    ]
    if not without_server:
        binaries.append(("SagaServer executable", "SagaServer"))
    for label, name in binaries:
        copy_file(resolved_input(available_inputs, label), output / "bin" / name, staged_inputs, label)

    tools = [
        ("sagaproject CLI", "sagaproject"),
        ("sagapack CLI", "sagapack"),
        ("sagascript CLI", "sagascript"),
        ("sde CLI", "sde"),
    ]
    for label, name in tools:
        copy_file(resolved_input(available_inputs, label), output / "tools" / name, staged_inputs, label)

    copy_tree(resolved_input(available_inputs, "StarterArena sample"), output / "samples" / "StarterArena", staged_inputs, "StarterArena sample")
    copy_file(resolved_input(available_inputs, "root README"), output / "docs" / "README.md", staged_inputs, "root README")
    copy_file(resolved_input(available_inputs, "getting started doc"), output / "docs" / "product" / "GETTING_STARTED.md", staged_inputs, "getting started doc")
    copy_file(resolved_input(available_inputs, "current capabilities doc"), output / "docs" / "product" / "CURRENT_CAPABILITIES.md", staged_inputs, "current capabilities doc")
    copy_file(resolved_input(available_inputs, "not implemented doc"), output / "docs" / "product" / "WHAT_IS_NOT_IMPLEMENTED.md", staged_inputs, "not implemented doc")
    copy_file(resolved_input(available_inputs, "distribution status doc"), output / "docs" / "product" / "CURRENT_DISTRIBUTION_STATUS.md", staged_inputs, "distribution status doc")
    copy_tree(resolved_input(available_inputs, "licenses"), output / "licenses", staged_inputs, "licenses")

    version_source = resolved_input(available_inputs, "root VERSION")
    copy_file(version_source, output / "VERSION", staged_inputs, "root VERSION")

    (output / "VERIFY.txt").write_text(verification_text(without_server=without_server), encoding="utf-8")
    staged_inputs.append(
        {
            "label": "staged VERIFY.txt",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "VERIFY.txt"),
        }
    )
    (output / "KNOWN_LIMITATIONS.md").write_text(known_limitations_text(), encoding="utf-8")
    staged_inputs.append(
        {
            "label": "staged known limitations",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "KNOWN_LIMITATIONS.md"),
        }
    )

    staged_inputs.append(
        {
            "label": "staged BUILD_INFO.json",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "BUILD_INFO.json"),
        }
    )

    build_info: dict[str, object] = {
        "schemaVersion": 1,
        "tool": "package-linux-saga",
        "status": "staged-with-blockers",
        "verified": False,
        "buildDir": path_text(build_dir),
        "output": path_text(output),
        "withoutServer": without_server,
        "stagedInputs": staged_inputs,
        "missingInputs": [],
        "nonClaims": [
            "This layout is not a final distribution.",
            "This layout does not claim package readiness.",
            "This layout does not claim distribution readiness.",
            "This layout does not include Saga.tar.zst.",
            "This layout does not include Saga.sha256.",
            "This layout does not mark any phase Verified.",
        ],
    }
    source_commit = git_commit()
    if source_commit is not None:
        build_info["sourceCommit"] = source_commit

    (output / "BUILD_INFO.json").write_text(
        json.dumps(build_info, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    return {
        "status": "staged",
        "output": path_text(output),
        "stagedInputs": staged_inputs,
        "nonClaims": build_info["nonClaims"],
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", default="Release", help="Build configuration label.")
    parser.add_argument("--build-dir", help="CMake build directory to inspect.")
    parser.add_argument("--output", default=str(DEFAULT_OUTPUT), help="Expected final distribution directory.")
    parser.add_argument(
        "--report-out",
        default=str(DEFAULT_REPORT),
        help="Machine-readable preflight report path.",
    )
    parser.add_argument("--without-server", action="store_true", help="Do not require SagaServer.")
    args = parser.parse_args()

    build_dir_candidates = [Path(args.build_dir)] if args.build_dir else default_build_dirs(args.config)
    build_dir = Path(args.build_dir) if args.build_dir else first_existing(build_dir_candidates)
    output = Path(args.output)
    report_path = Path(args.report_out)
    missing: list[str] = []
    required_inputs: list[dict[str, object]] = []
    available_inputs: list[dict[str, object]] = []
    missing_inputs: list[dict[str, object]] = []

    if build_dir is None:
        message = "build directory: no candidate build directory exists"
        missing.append(message)
        record_check(
            label="build directory",
            kind="directory",
            category="build",
            paths=build_dir_candidates,
            available=False,
            required_inputs=required_inputs,
            available_inputs=available_inputs,
            missing_inputs=missing_inputs,
            message=message,
        )
        build_dir = Path("build")
    else:
        record_check(
            label="build directory",
            kind="directory",
            category="build",
            paths=build_dir_candidates,
            available=True,
            required_inputs=required_inputs,
            available_inputs=available_inputs,
            missing_inputs=missing_inputs,
            resolved_path=build_dir,
        )

    bin_dir = build_dir / "bin"
    check_binary("Saga product shell", [bin_dir / "Saga"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    check_binary("SagaEditor shell", [bin_dir / "SagaEditor"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    check_binary("SagaRuntime executable", [bin_dir / "SagaRuntime"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    if not args.without_server:
        check_binary("SagaServer executable", [bin_dir / "SagaServer"], missing, required_inputs, available_inputs, missing_inputs, category="binary")

    check_binary("sagaproject CLI", [Path("Tools/SagaProjectKit/sagaproject")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_binary("sagapack CLI", [Path("Tools/SagaPackager/sagapack")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_binary("sagascript CLI", [Path("Tools/SagaScript/sagascript")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_binary(
        "sde CLI",
        [
            bin_dir / "sde",
            Path("Tools/SystemDefinitionEngine/bin/sde"),
            Path("Tools/SystemDefinitionEngine/build/bin/sde"),
            Path("Tools/SystemDefinitionEngine/build/sde"),
        ],
        missing,
        required_inputs,
        available_inputs,
        missing_inputs,
        category="tool",
    )

    check_dir("StarterArena sample", Path("samples/StarterArena"), missing, required_inputs, available_inputs, missing_inputs, category="sample")
    check_file("root VERSION", Path("VERSION"), missing, required_inputs, available_inputs, missing_inputs, category="metadata")
    check_file("root README", Path("README.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("getting started doc", Path("docs/product/GETTING_STARTED.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("current capabilities doc", Path("docs/product/CURRENT_CAPABILITIES.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("not implemented doc", Path("docs/product/WHAT_IS_NOT_IMPLEMENTED.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("distribution status doc", Path("docs/product/CURRENT_DISTRIBUTION_STATUS.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_dir("licenses", Path("LICENSES"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")

    staging_status: dict[str, object]
    if missing:
        staging_status = {
            "status": "blocked",
            "output": path_text(output),
            "message": "layout staging skipped because required real inputs are missing",
        }
    else:
        staging_status = stage_layout(
            output=output,
            build_dir=build_dir,
            available_inputs=available_inputs,
            without_server=bool(args.without_server),
        )

    check_dir("expected final distribution layout", output, missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution VERSION", output / "VERSION", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution VERIFY.txt", output / "VERIFY.txt", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution known limitations", output / "KNOWN_LIMITATIONS.md", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution archive", Path("build/dist/linux/Saga.tar.zst"), missing, required_inputs, available_inputs, missing_inputs, category="archive")
    check_file("expected distribution checksum", Path("build/dist/linux/Saga.sha256"), missing, required_inputs, available_inputs, missing_inputs, category="checksum")

    status = "blocked" if missing else "preflight-passed"
    distribution_items = [
        item for item in required_inputs if item.get("category") == "distribution-layout"
    ]
    distribution_missing = [
        item for item in distribution_items if item.get("status") == "missing"
    ]
    distribution_available = [
        item for item in distribution_items if item.get("status") == "available"
    ]
    report: dict[str, object] = {
        "schemaVersion": 1,
        "tool": "package-linux-saga",
        "status": status,
        "verified": False,
        "config": {
            "config": args.config,
            "withoutServer": bool(args.without_server),
            "buildDirArgument": args.build_dir,
            "outputArgument": args.output,
            "reportOut": path_text(report_path),
        },
        "buildDir": path_text(build_dir),
        "expectedOutput": path_text(output),
        "requiredInputs": required_inputs,
        "availableInputs": available_inputs,
        "missingInputs": missing_inputs,
        "distributionLayoutStatus": {
            "expectedPath": path_text(output),
            "status": "blocked" if distribution_missing else "available",
            "availableEntries": distribution_available,
            "missingEntries": distribution_missing,
        },
        "stagingStatus": staging_status,
        "archiveStatus": {
            "path": "build/dist/linux/Saga.tar.zst",
            "status": status_for_label(required_inputs, "expected distribution archive"),
        },
        "checksumStatus": {
            "path": "build/dist/linux/Saga.sha256",
            "status": status_for_label(required_inputs, "expected distribution checksum"),
        },
        "diagnostics": missing
        if missing
        else [
            "preflight passed for currently checked inputs",
            "layout staging completed from real existing inputs",
        ],
        "knownLimitations": [
            "This script stages only the Linux layout directory from real existing inputs.",
            "This script does not build missing tools, including the standalone SDE CLI.",
            "This script does not create Saga.tar.zst.",
            "This script does not create Saga.sha256.",
            "The staged layout is not a final distribution.",
            "A passing preflight report is not maintainer verification.",
        ],
        "nonClaims": [
            "No package archive or checksum files were generated by scripts/package-linux-saga.",
            "This report does not claim package readiness.",
            "This report does not claim distribution readiness.",
            "This report does not prove runtime, editor, server, or tool workflows beyond input existence checks.",
            "This report does not mark any phase Verified.",
        ],
    }
    write_report(report_path, report)

    print("package-linux-saga: layout staging plus preflight; no archive or checksum generated")
    print(f"package-linux-saga: config={args.config}")
    print(f"package-linux-saga: build_dir={build_dir}")
    print(f"package-linux-saga: expected_output={output}")
    print(f"package-linux-saga: staging_status={staging_status.get('status')}")

    if missing:
        print("package-linux-saga: failed; required real inputs/output layout are missing:")
        for item in missing:
            print(f"- {item}")
        return 1

    print("package-linux-saga: preflight passed; archive/checksum generation is still not implemented")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
