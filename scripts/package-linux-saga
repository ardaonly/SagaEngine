    docs: dict[str, str] = {
        "BUILDING_FROM_SOURCE.md": """# Building From Source

The source-tree build path is the supported way to regenerate this Linux
candidate evidence.

```bash
Tools/Forge/bin/forge nix build --build build/RelWithDebInfo-0.0.9
scripts/package-linux-saga --config Release
scripts/smoke-linux-saga-dist
scripts/verify-linux-saga-candidate
scripts/verify-linux-distribution-contract
```

This document does not claim production readiness, enterprise readiness, a
verified final release, full gameplay readiness, full editor workflow, or full
Visual Blocks UI.
""",
        "SCRIPTING.md": """# SagaScript Current Distribution Notes

This distribution includes packaged SagaScript tooling and StarterArena script
inputs used for limited evidence. The evidence proves analysis and selected
compile/smoke paths where reports say they passed.

It does not prove arbitrary C# support, full gameplay readiness, production
readiness, enterprise readiness, or a verified final release.
""",
        "VISUAL_BLOCKS.md": """# Visual Blocks Current Distribution Notes

Visual Blocks evidence is limited to compatible C# projection and opaque-node
behavior described by the current reports. The packaged distribution does not
claim a full Visual Blocks UI or arbitrary C# to blocks.

This document does not claim production readiness, enterprise readiness, full
editor workflow, full gameplay readiness, or a verified final release.
""",
        "PACKAGING.md": """# Packaging Current Distribution Notes

`scripts/package-linux-saga` stages the Linux candidate layout from real
existing binaries, tools, docs, licenses, and sample inputs, then generates the
archive and checksum.

Passing package evidence does not prove production readiness, enterprise
readiness, full distribution certification, full gameplay readiness, or a
verified final release.
""",
        "CUSTOMIZATION.md": """# Customization Current Distribution Notes

SagaEngine currently carries profile/customization direction evidence, but the
Linux candidate package does not claim a complete editor customization product
workflow.

This document does not claim full editor workflow, full Visual Blocks UI,
production readiness, enterprise readiness, or a verified final release.
""",
    }
    return docs[name]


def known_limitations_text() -> str:
    return """# Saga Linux Layout Known Limitations

This staged layout is not a final distribution.

- Not production-ready.
- Not enterprise-ready.
- Not a verified release.
- Not a verified final release.
- Not full distribution validation.
- Archive/checksum evidence is limited to `Saga.tar.zst` and `Saga.sha256`.
- Packaged .NET tool wrappers dispatch to real framework-dependent published artifacts and require a compatible .NET runtime.
- No full editor UI is claimed.
- No Visual Blocks editor UI is claimed.
- No enterprise collaboration is claimed.
- No cloud workspace is claimed.
- No package readiness is claimed unless `scripts/package-linux-saga` passes all required checks.
- Runtime, editor, server, and tool workflows are not proven beyond real input existence checks.
- No phase is marked Verified by this staged layout.
"""


def stage_layout(
    *,
    output: Path,
    build_dir: Path,
    build_type: str,
    available_inputs: list[dict[str, object]],
    missing: list[str],
    required_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
) -> dict[str, object]:
    staged_inputs: list[dict[str, object]] = []

    if output.exists():
        shutil.rmtree(output)
    output.mkdir(parents=True, exist_ok=True)

    binaries = [
        ("Saga product shell", "Saga"),
        ("SagaEditor shell", "SagaEditor"),
        ("SagaRuntime executable", "SagaRuntime"),
    ]
    for label, name in binaries:
        copy_file(resolved_input(available_inputs, label), output / "bin" / name, staged_inputs, label)

    tool_packaging_status = stage_packaged_dotnet_tools(
        output=output,
        staged_inputs=staged_inputs,
        missing=missing,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
    )

    copy_tree(resolved_input(available_inputs, "StarterArena sample"), output / "samples" / "StarterArena", staged_inputs, "StarterArena sample")
    copy_file(resolved_input(available_inputs, "root README"), output / "docs" / "README.md", staged_inputs, "root README")
    copy_file(resolved_input(available_inputs, "root README"), output / "README.md", staged_inputs, "root README top-level")
    copy_file(resolved_input(available_inputs, "getting started doc"), output / "docs" / "product" / "GETTING_STARTED.md", staged_inputs, "getting started doc")
    copy_file(resolved_input(available_inputs, "getting started doc"), output / "docs" / "GETTING_STARTED.md", staged_inputs, "getting started doc top-level")
    copy_file(resolved_input(available_inputs, "current capabilities doc"), output / "docs" / "product" / "CURRENT_CAPABILITIES.md", staged_inputs, "current capabilities doc")
    copy_file(resolved_input(available_inputs, "current capabilities doc"), output / "docs" / "CURRENT_CAPABILITIES.md", staged_inputs, "current capabilities doc top-level")
    copy_file(resolved_input(available_inputs, "not implemented doc"), output / "docs" / "product" / "WHAT_IS_NOT_IMPLEMENTED.md", staged_inputs, "not implemented doc")
    copy_file(resolved_input(available_inputs, "not implemented doc"), output / "docs" / "KNOWN_LIMITATIONS.md", staged_inputs, "known limitations doc top-level")
    copy_file(resolved_input(available_inputs, "distribution status doc"), output / "docs" / "product" / "CURRENT_DISTRIBUTION_STATUS.md", staged_inputs, "distribution status doc")
    copy_tree(resolved_input(available_inputs, "licenses"), output / "licenses", staged_inputs, "licenses")

    for generated_name in [
        "BUILDING_FROM_SOURCE.md",
        "SCRIPTING.md",
        "VISUAL_BLOCKS.md",
        "PACKAGING.md",
        "CUSTOMIZATION.md",
    ]:
        generated_path = output / "docs" / generated_name
        generated_path.write_text(generated_distribution_doc(generated_name), encoding="utf-8")
        staged_inputs.append(
            {
                "label": f"generated distribution doc {generated_name}",
                "kind": "generated-documentation",
                "source": "scripts/package-linux-saga",
                "destination": path_text(generated_path),
            }
        )

    version_source = resolved_input(available_inputs, "root VERSION")
    copy_file(version_source, output / "VERSION", staged_inputs, "root VERSION")

    (output / "VERIFY.txt").write_text(verification_text(), encoding="utf-8")
    staged_inputs.append(
        {
            "label": "staged VERIFY.txt",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "VERIFY.txt"),
        }
    )
    (output / "KNOWN_LIMITATIONS.md").write_text(known_limitations_text(), encoding="utf-8")
    staged_inputs.append(
        {
            "label": "staged known limitations",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "KNOWN_LIMITATIONS.md"),
        }
    )

    staged_inputs.append(
        {
            "label": "staged BUILD_INFO.json",
            "kind": "generated-metadata",
            "source": "scripts/package-linux-saga",
            "destination": path_text(output / "BUILD_INFO.json"),
        }
    )

    source_commit = git_commit()
    built_at_utc = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    included_targets = ["Saga", "SagaEditor", "SagaRuntime"]
    build_info: dict[str, object] = {
        "schemaVersion": 1,
        "product": "SagaEngine",
        "channel": "technical-preview-candidate",
        "platform": "linux",
        "version": read_version(),
        "commit": source_commit,
        "buildType": build_type,
        "builtAtUtc": built_at_utc,
        "includedTargets": included_targets,
        "publicTools": ["sagaproject", "sagapack", "sagascript"],
        "samples": ["StarterArena"],
        "knownLimitationsFile": "KNOWN_LIMITATIONS.md",
        "verification": {
            "verified": False,
            "status": "layout-staged-for-archive",
            "packageReport": "build/reports/linux_package_preflight_report.json",
            "smokeReport": "build/reports/linux_distribution_smoke_report.json",
            "candidateReport": "build/reports/linux_distributable_candidate_report.json",
            "contractReport": "build/reports/linux_distribution_contract_report.json",
        },
        "tool": "package-linux-saga",
        "status": "layout-staged-for-archive",
        "verified": False,
        "archiveTarget": path_text(archive_path_for(output)),
        "buildDir": path_text(build_dir),
        "checksumTarget": path_text(checksum_path_for(output)),
        "output": path_text(output),
        "stagedInputs": staged_inputs,
        "toolPackagingStatus": tool_packaging_status,
        "missingInputs": missing,
        "staging": {
            "stagedInputs": staged_inputs,
            "toolPackagingStatus": tool_packaging_status,
            "missingInputs": missing,
        },
        "finalAcceptanceGaps": [
            "lib/ is not staged unless real shared library distribution artifacts are produced.",
            "include/ is not staged unless real public SDK headers are selected for distribution.",
            "share/saga/ is not staged unless real templates, profiles, schemas, plugins, or CMake package files are selected for distribution.",
            "Packaged Runtime and Editor workflows remain bounded by the current smoke reports.",
        ],
        "nonClaims": [
            "This layout is not a final distribution.",
            "This layout does not claim production readiness.",
            "This layout does not claim enterprise readiness.",
            "This layout does not claim a verified release.",
            "This layout does not claim a verified final release.",
            "This layout does not claim full distribution validation.",
            "This layout does not claim full gameplay readiness.",
            "This layout does not claim full editor workflow.",
            "This layout does not claim full Visual Blocks UI.",
            "This layout does not claim full packaged tool workflow validation.",
            "This layout does not mark any phase Verified.",
        ],
    }
    if source_commit is not None:
        build_info["sourceCommit"] = source_commit

    (output / "BUILD_INFO.json").write_text(
        json.dumps(build_info, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    return {
        "status": "staged",
        "output": path_text(output),
        "stagedInputs": staged_inputs,
        "toolPackagingStatus": tool_packaging_status,
        "nonClaims": build_info["nonClaims"],
    }


def stale_package_outputs(archive_path: Path, checksum_path: Path) -> None:
    for path in [checksum_path, archive_path]:
        if path.exists():
            path.unlink()


def staged_layout_missing(output: Path) -> list[str]:
    required_files = [
        "VERSION",
        "VERIFY.txt",
        "KNOWN_LIMITATIONS.md",
        "BUILD_INFO.json",
        "README.md",
        "bin/Saga",
        "bin/SagaEditor",
        "bin/SagaRuntime",
        "bin/sagaproject",
        "bin/sagapack",
        "bin/sagascript",
        "tools/sagaproject",
        "tools/sagapack",
        "tools/sagascript",
        "docs/README.md",
        "docs/GETTING_STARTED.md",
        "docs/CURRENT_CAPABILITIES.md",
        "docs/KNOWN_LIMITATIONS.md",
        "docs/BUILDING_FROM_SOURCE.md",
        "docs/SCRIPTING.md",
        "docs/VISUAL_BLOCKS.md",
        "docs/PACKAGING.md",
        "docs/CUSTOMIZATION.md",
    ]
    required_dirs = [
        "samples/StarterArena",
        "docs/product",
        "licenses",
    ]

    missing_entries: list[str] = []
    if not output.is_dir():
        missing_entries.append(path_text(output))
        return missing_entries

    executable_rels = {
        "bin/Saga",
        "bin/SagaEditor",
        "bin/SagaRuntime",
        "bin/sagaproject",
        "bin/sagapack",
        "bin/sagascript",
        "tools/sagaproject",
        "tools/sagapack",
        "tools/sagascript",
    }
    for rel in required_files:
        path = output / rel
        if rel in executable_rels:
            if not is_executable(path):
                missing_entries.append(path_text(path))
        elif not path.is_file():
            missing_entries.append(path_text(path))
    for rel in required_dirs:
        path = output / rel
        if not path.is_dir():
            missing_entries.append(path_text(path))
    return missing_entries


def tar_supports_zstd() -> bool:
    if shutil.which("tar") is None or shutil.which("zstd") is None:
        return False
    result = subprocess.run(
        ["tar", "--help"],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return result.returncode == 0 and "--zstd" in result.stdout


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def archive_root_is_valid(archive_path: Path, root_name: str) -> bool:
    result = subprocess.run(
        ["tar", "-tf", str(archive_path)],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0:
        return False
    entries = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    return bool(entries) and all(entry == root_name or entry.startswith(f"{root_name}/") for entry in entries)


def generate_archive_and_checksum(
    *,
    output: Path,
    archive_path: Path,
    checksum_path: Path,
    missing: list[str],
    required_inputs: list[dict[str, object]],
    available_inputs: list[dict[str, object]],
    missing_inputs: list[dict[str, object]],
) -> dict[str, object]:
    stale_package_outputs(archive_path, checksum_path)
    status: dict[str, object] = {
        "archivePath": path_text(archive_path),
        "checksumPath": path_text(checksum_path),
        "status": "blocked",
    }

    layout_missing = staged_layout_missing(output)
    layout_ready = not layout_missing
    layout_message = None
    if not layout_ready:
        layout_message = "staged layout incomplete; archive/checksum generation skipped: " + ", ".join(layout_missing)
        missing.append(layout_message)
    record_check(
        label="staged layout completeness for archive",
        kind="directory",
        category="archive",
        paths=[output],
        available=layout_ready,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=output if layout_ready else None,
        message=layout_message,
    )
    if not layout_ready:
        status["message"] = layout_message
        return status

    tool_ready = tar_supports_zstd()
    tool_paths = [Path(shutil.which("tar") or "tar"), Path(shutil.which("zstd") or "zstd")]
    tool_message = None
    if not tool_ready:
        tool_message = "archive tool: missing tar with --zstd support or zstd executable"
        missing.append(tool_message)
    record_check(
        label="tar zstd archive tools",
        kind="tool",
        category="archive-tool",
        paths=tool_paths,
        available=tool_ready,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=tool_paths[0] if tool_ready else None,
        message=tool_message,
    )
    if not tool_ready:
        status["message"] = tool_message
        return status

    archive_command = [
        "tar",
        "--zstd",
        "--sort=name",
        "--mtime=@0",
        "--owner=0",
        "--group=0",
        "--numeric-owner",
        "-cf",
        str(archive_path),
        "-C",
        str(output.parent),
        output.name,
    ]
    archive_result = subprocess.run(
        archive_command,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    archive_ready = (
        archive_result.returncode == 0
        and archive_path.is_file()
        and archive_path.stat().st_size > 0
        and archive_root_is_valid(archive_path, output.name)
    )
    archive_message = None
    if not archive_ready:
        stale_package_outputs(archive_path, checksum_path)
        archive_error = archive_result.stderr.strip() or "archive generation failed"
        archive_message = f"archive generation failed: {archive_error}"
        missing.append(archive_message)
    record_check(
        label="archive generation",
        kind="file",
        category="archive",
        paths=[archive_path],
        available=archive_ready,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=archive_path if archive_ready else None,
        message=archive_message,
    )
    if not archive_ready:
        status["message"] = archive_message
        return status

    checksum = sha256_file(archive_path)
    checksum_path.write_text(f"{checksum}  {archive_path.name}\n", encoding="utf-8")
    checksum_ready = checksum_path.is_file() and checksum_path.stat().st_size > 0
    checksum_message = None
    if not checksum_ready:
        checksum_message = f"checksum generation failed: {checksum_path}"
        missing.append(checksum_message)
    record_check(
        label="checksum generation",
        kind="file",
        category="checksum",
        paths=[checksum_path],
        available=checksum_ready,
        required_inputs=required_inputs,
        available_inputs=available_inputs,
        missing_inputs=missing_inputs,
        resolved_path=checksum_path if checksum_ready else None,
        message=checksum_message,
    )
    if not checksum_ready:
        return {
            "archivePath": path_text(archive_path),
            "checksumPath": path_text(checksum_path),
            "status": "blocked",
            "message": checksum_message,
        }

    return {
        "archivePath": path_text(archive_path),
        "archiveRoot": output.name,
        "checksumPath": path_text(checksum_path),
        "checksumAlgorithm": "sha256",
        "status": "available",
        "nonClaims": [
            "Archive/checksum generation does not claim production readiness.",
            "Archive/checksum generation does not claim enterprise readiness.",
            "Archive/checksum generation does not claim a verified release.",
            "Archive/checksum generation does not claim a verified final release.",
            "Archive/checksum generation does not claim full distribution validation.",
        ],
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", default="Release", help="Build configuration label.")
    parser.add_argument("--build-dir", help="CMake build directory to inspect.")
    parser.add_argument("--output", default=str(DEFAULT_OUTPUT), help="Expected final distribution directory.")
    parser.add_argument(
        "--report-out",
        default=str(DEFAULT_REPORT),
        help="Machine-readable preflight report path.",
    )
    args = parser.parse_args()

    build_dir_candidates = [Path(args.build_dir)] if args.build_dir else default_build_dirs(args.config)
    build_dir = Path(args.build_dir) if args.build_dir else first_existing(build_dir_candidates)
    output = Path(args.output)
    archive_path = archive_path_for(output)
    checksum_path = checksum_path_for(output)
    report_path = Path(args.report_out)
    missing: list[str] = []
    required_inputs: list[dict[str, object]] = []
    available_inputs: list[dict[str, object]] = []
    missing_inputs: list[dict[str, object]] = []

    if build_dir is None:
        message = "build directory: no candidate build directory exists"
        missing.append(message)
        record_check(
            label="build directory",
            kind="directory",
            category="build",
            paths=build_dir_candidates,
            available=False,
            required_inputs=required_inputs,
            available_inputs=available_inputs,
            missing_inputs=missing_inputs,
            message=message,
        )
        build_dir = Path("build")
    else:
        record_check(
            label="build directory",
            kind="directory",
            category="build",
            paths=build_dir_candidates,
            available=True,
            required_inputs=required_inputs,
            available_inputs=available_inputs,
            missing_inputs=missing_inputs,
            resolved_path=build_dir,
        )

    bin_dir = build_dir / "bin"
    check_binary("Saga product shell", [bin_dir / "Saga"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    check_binary("SagaEditor shell", [bin_dir / "SagaEditor"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    check_binary("SagaRuntime executable", [bin_dir / "SagaRuntime"], missing, required_inputs, available_inputs, missing_inputs, category="binary")
    check_binary("sagaproject CLI", [Path("Tools/SagaProjectKit/sagaproject")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_binary("sagapack CLI", [Path("Tools/SagaPackager/sagapack")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_binary("sagascript CLI", [Path("Tools/SagaScript/sagascript")], missing, required_inputs, available_inputs, missing_inputs, category="tool")
    check_dir("StarterArena sample", Path("samples/StarterArena"), missing, required_inputs, available_inputs, missing_inputs, category="sample")
    check_file("root VERSION", Path("VERSION"), missing, required_inputs, available_inputs, missing_inputs, category="metadata")
    check_file("root README", Path("README.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("getting started doc", Path("docs/product/GETTING_STARTED.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("current capabilities doc", Path("docs/product/CURRENT_CAPABILITIES.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("not implemented doc", Path("docs/product/WHAT_IS_NOT_IMPLEMENTED.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_file("distribution status doc", Path("docs/product/CURRENT_DISTRIBUTION_STATUS.md"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")
    check_dir("licenses", Path("LICENSES"), missing, required_inputs, available_inputs, missing_inputs, category="documentation")

    staging_status: dict[str, object]
    if missing:
        stale_package_outputs(archive_path, checksum_path)
        staging_status = {
            "status": "blocked",
            "output": path_text(output),
            "message": "layout staging skipped because required real inputs are missing",
        }
    else:
        staging_status = stage_layout(
            output=output,
            build_dir=build_dir,
            build_type=args.config,
            available_inputs=available_inputs,
            missing=missing,
            required_inputs=required_inputs,
            missing_inputs=missing_inputs,
        )

    archive_generation_status: dict[str, object] = {
        "archivePath": path_text(archive_path),
        "checksumPath": path_text(checksum_path),
        "status": "skipped",
    }
    if not missing:
        archive_generation_status = generate_archive_and_checksum(
            output=output,
            archive_path=archive_path,
            checksum_path=checksum_path,
            missing=missing,
            required_inputs=required_inputs,
            available_inputs=available_inputs,
            missing_inputs=missing_inputs,
        )

    check_dir("expected final distribution layout", output, missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution VERSION", output / "VERSION", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution VERIFY.txt", output / "VERIFY.txt", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution known limitations", output / "KNOWN_LIMITATIONS.md", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    check_file("expected distribution README", output / "README.md", missing, required_inputs, available_inputs, missing_inputs, category="distribution-layout")
    for tool_name in ["sagaproject", "sagapack", "sagascript"]:
        check_binary(
            f"expected distribution public {tool_name}",
            [output / "bin" / tool_name],
            missing,
            required_inputs,
            available_inputs,
            missing_inputs,
            category="distribution-layout",
        )
    for doc_name in [
        "GETTING_STARTED.md",
        "CURRENT_CAPABILITIES.md",
        "KNOWN_LIMITATIONS.md",
        "BUILDING_FROM_SOURCE.md",
        "SCRIPTING.md",
        "VISUAL_BLOCKS.md",
        "PACKAGING.md",
        "CUSTOMIZATION.md",
    ]:
        check_file(
            f"expected distribution doc {doc_name}",
            output / "docs" / doc_name,
            missing,
            required_inputs,
            available_inputs,
            missing_inputs,
            category="distribution-layout",
        )
    check_file("expected distribution archive", archive_path, missing, required_inputs, available_inputs, missing_inputs, category="archive")
    check_file("expected distribution checksum", checksum_path, missing, required_inputs, available_inputs, missing_inputs, category="checksum")

    status = "blocked" if missing else "preflight-passed"
    distribution_items = [
        item for item in required_inputs if item.get("category") == "distribution-layout"
    ]
    distribution_missing = [
        item for item in distribution_items if item.get("status") == "missing"
    ]
    distribution_available = [
        item for item in distribution_items if item.get("status") == "available"
    ]
    report: dict[str, object] = {
        "schemaVersion": 1,
        "tool": "package-linux-saga",
        "status": status,
        "verified": False,
        "config": {
            "config": args.config,
            "buildDirArgument": args.build_dir,
            "outputArgument": args.output,
            "reportOut": path_text(report_path),
        },
        "buildDir": path_text(build_dir),
        "expectedOutput": path_text(output),
        "requiredInputs": required_inputs,
        "availableInputs": available_inputs,
        "missingInputs": missing_inputs,
        "distributionLayoutStatus": {
            "expectedPath": path_text(output),
            "status": "blocked" if distribution_missing else "available",
            "availableEntries": distribution_available,
            "missingEntries": distribution_missing,
        },
        "stagingStatus": staging_status,
        "archiveGenerationStatus": archive_generation_status,
        "archiveStatus": {
            "path": path_text(archive_path),
            "status": status_for_label(required_inputs, "expected distribution archive"),
        },
        "checksumStatus": {
            "path": path_text(checksum_path),
            "status": status_for_label(required_inputs, "expected distribution checksum"),
        },
        "diagnostics": missing
        if missing
        else [
            "preflight passed for currently checked inputs",
            "layout staging completed from real existing inputs",
            "archive/checksum generated from the staged layout",
            "production, enterprise, and verified final release readiness are not claimed",
        ],
        "knownLimitations": [
            "This script stages only the Linux layout directory from real existing inputs.",
            "This script does not build missing engine binaries.",
            "This script publishes sagaproject, sagascript, and sagapack only from real existing .NET projects when a .NET 10 SDK is available.",
            "This script creates only Saga.tar.zst and Saga.sha256 from the staged layout.",
            "This script stages sagaproject, sagascript, and sagapack from real framework-dependent dotnet publish outputs.",
            "Archive/checksum generation does not prove runtime, editor, server, or tool workflows.",
            "Archive/checksum generation does not prove full distribution validation.",
            "A passing preflight report is not maintainer verification.",
        ],
        "nonClaims": [
            "This report does not claim production readiness; the package is not production-ready.",
            "This report does not claim enterprise readiness; the package is not enterprise-ready.",
            "This report does not claim a verified release.",
            "This report does not claim a verified final release.",
            "This report does not claim full distribution validation.",
            "This report does not claim full editor UI readiness.",
            "This report does not claim Visual Blocks editor UI readiness.",
            "This report does not claim cloud collaboration readiness.",
            "This report does not prove runtime, editor, server, or tool workflows beyond input existence checks.",
            "This report does not mark any phase Verified.",
        ],
    }
    write_report(report_path, report)

    print("package-linux-saga: layout staging plus archive/checksum preflight")
    print(f"package-linux-saga: config={args.config}")
    print(f"package-linux-saga: build_dir={build_dir}")
    print(f"package-linux-saga: expected_output={output}")
    print(f"package-linux-saga: staging_status={staging_status.get('status')}")
    print(f"package-linux-saga: archive_status={archive_generation_status.get('status')}")

    if missing:
        print("package-linux-saga: failed; required real inputs/output layout are missing:")
        for item in missing:
            print(f"- {item}")
        return 1

    print("package-linux-saga: preflight passed; archive/checksum generated without readiness claims")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
