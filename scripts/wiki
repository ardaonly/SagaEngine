#!/usr/bin/env python3
"""Build and verify the offline, Markdown-backed SagaWiki knowledge reader."""

from __future__ import annotations

import html
import json
import posixpath
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parent.parent
WIKI_ROOT = REPO_ROOT / "SagaWiki"
REGISTRY_PATH = WIKI_ROOT / "wiki-library.json"
INDEX_PATH = WIKI_ROOT / "index.html"
STYLE_PATH = WIKI_ROOT / "assets" / "style.css"
SCRIPT_PATH = WIKI_ROOT / "assets" / "wiki.js"
DCO_SOURCE_PATH = WIKI_ROOT / "policy" / "contributing-dco.md"
DCO_BRIDGE_PATH = WIKI_ROOT / "pages" / "licensing.html"
DCO_MARKER_BEGIN = "<!-- SAGA-LICENSING-DCO:BEGIN -->"
DCO_MARKER_END = "<!-- SAGA-LICENSING-DCO:END -->"
ALLOWED_STATUS = {"current", "bounded", "guide", "policy"}
REQUIRED_META = {"title", "status", "owner", "reviewed_against"}
BANNED_NAME_PARTS = {
    "MILESTONE",
    "TECHNICAL_PREVIEW",
    "SMALL_TEAM_ALPHA",
    "HARDENING_PLAN",
    "INVENTORY",
    "AUDIT",
    "PHASE",
}
CLAIM_PATTERNS = (
    "finished public sdk",
    "finished editor",
    "production networking",
    "production collaboration",
    "shipped persistent worlds",
    "shipped persistent community worlds",
)
NEGATION_WORDS = (
    " no ",
    " not ",
    "without ",
    "does not ",
    "do not ",
    "isn't ",
    "is not ",
    "must not ",
)


class WikiError(RuntimeError):
    """A deterministic Wiki source or generation error."""


@dataclass
class Article:
    entry: dict[str, Any]
    metadata: dict[str, str]
    markdown: str
    body: str
    rendered: str
    toc: list[dict[str, str]]


def load_json(path: Path) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise WikiError(f"missing registry: {path.relative_to(REPO_ROOT)}") from exc
    except json.JSONDecodeError as exc:
        raise WikiError(f"invalid registry JSON: {exc}") from exc
    if not isinstance(value, dict):
        raise WikiError("wiki-library.json must contain a JSON object")
    return value


def parse_front_matter(text: str, source: str) -> tuple[dict[str, str], str]:
    lines = text.splitlines()
    if not lines or lines[0] != "---":
        raise WikiError(f"{source}: missing opening front matter delimiter")
    try:
        end = lines.index("---", 1)
    except ValueError as exc:
        raise WikiError(f"{source}: missing closing front matter delimiter") from exc

    metadata: dict[str, str] = {}
    for number, line in enumerate(lines[1:end], 2):
        if not line.strip():
            continue
        if ":" not in line:
            raise WikiError(f"{source}:{number}: malformed front matter")
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if not key or not value or key in metadata:
            raise WikiError(f"{source}:{number}: invalid or duplicate metadata key")
        metadata[key] = value

    missing = REQUIRED_META - metadata.keys()
    if missing:
        raise WikiError(f"{source}: missing metadata: {', '.join(sorted(missing))}")
    body = "\n".join(lines[end + 1 :]).strip() + "\n"
    return metadata, body


def slugify(value: str) -> str:
    value = re.sub(r"`([^`]*)`", r"\1", value).lower()
    value = re.sub(r"[^a-z0-9]+", "-", value).strip("-")
    return value or "section"


def resolve_link(target: str, source: str, source_to_id: dict[str, str]) -> str:
    if target.startswith(("https://", "http://", "mailto:", "#")):
        return target
    path, marker, fragment = target.partition("#")
    if path.endswith(".md"):
        resolved = posixpath.normpath(posixpath.join(posixpath.dirname(source), path))
        article_id = source_to_id.get(resolved)
        if article_id:
            suffix = f"/{slugify(fragment)}" if marker and fragment else ""
            return f"#{article_id}{suffix}"
    return target


INLINE_RE = re.compile(
    r"`([^`]+)`|\[([^\]]+)\]\(([^)]+)\)|\*\*([^*]+)\*\*|(?<!\*)\*([^*]+)\*(?!\*)"
)


def render_inline(text: str, source: str, source_to_id: dict[str, str]) -> str:
    output: list[str] = []
    cursor = 0
    for match in INLINE_RE.finditer(text):
        output.append(html.escape(text[cursor : match.start()]))
        code, label, target, strong, emphasis = match.groups()
        if code is not None:
            output.append(f"<code>{html.escape(code)}</code>")
        elif label is not None and target is not None:
            href = resolve_link(target.strip(), source, source_to_id)
            output.append(
                f'<a href="{html.escape(href, quote=True)}">{html.escape(label)}</a>'
            )
        elif strong is not None:
            output.append(f"<strong>{html.escape(strong)}</strong>")
        elif emphasis is not None:
            output.append(f"<em>{html.escape(emphasis)}</em>")
        cursor = match.end()
    output.append(html.escape(text[cursor:]))
    return "".join(output)


def split_table_row(line: str) -> list[str]:
    return [cell.strip() for cell in line.strip().strip("|").split("|")]


def is_table_rule(line: str) -> bool:
    cells = split_table_row(line)
    return bool(cells) and all(re.fullmatch(r":?-{3,}:?", cell) for cell in cells)


def render_markdown(
    body: str, source: str, article_id: str, source_to_id: dict[str, str]
) -> tuple[str, list[dict[str, str]]]:
    lines = body.splitlines()
    output: list[str] = []
    toc: list[dict[str, str]] = []
    used_slugs: dict[str, int] = {}
    i = 0

    def heading_slug(title: str) -> str:
        base = slugify(title)
        used_slugs[base] = used_slugs.get(base, 0) + 1
        return base if used_slugs[base] == 1 else f"{base}-{used_slugs[base]}"

    while i < len(lines):
        line = lines[i]
        if not line.strip():
            i += 1
            continue

        fence = re.match(r"^```\s*([A-Za-z0-9_+.-]*)\s*$", line)
        if fence:
            language = fence.group(1)
            code_lines: list[str] = []
            i += 1
            while i < len(lines) and not lines[i].startswith("```"):
                code_lines.append(lines[i])
                i += 1
            if i == len(lines):
                raise WikiError(f"{source}: unclosed fenced code block")
            language_attr = f' class="language-{html.escape(language)}"' if language else ""
            output.append(
                f"<pre><code{language_attr}>{html.escape(chr(10).join(code_lines))}</code></pre>"
            )
            i += 1
            continue

        heading = re.match(r"^(#{1,3})\s+(.+?)\s*$", line)
        if heading:
            level = len(heading.group(1))
            title = heading.group(2)
            slug = heading_slug(title)
            output.append(
                f'<h{level} id="{html.escape(slug)}">'
                f"{render_inline(title, source, source_to_id)}</h{level}>"
            )
            if level > 1:
                toc.append({"title": re.sub(r"[`*_]", "", title), "slug": slug, "level": str(level)})
            i += 1
            continue

        if line.strip() in {"---", "***"}:
            output.append("<hr>")
            i += 1
            continue

        if i + 1 < len(lines) and "|" in line and is_table_rule(lines[i + 1]):
            headers = split_table_row(line)
            i += 2
            rows: list[list[str]] = []
            while i < len(lines) and "|" in lines[i] and lines[i].strip():
                rows.append(split_table_row(lines[i]))
                i += 1
            output.append("<div class=\"table-scroll\"><table><thead><tr>")
            output.extend(
                f"<th>{render_inline(cell, source, source_to_id)}</th>" for cell in headers
            )
            output.append("</tr></thead><tbody>")
            for row in rows:
                output.append("<tr>")
                for column in range(len(headers)):
                    value = row[column] if column < len(row) else ""
                    output.append(f"<td>{render_inline(value, source, source_to_id)}</td>")
                output.append("</tr>")
            output.append("</tbody></table></div>")
            continue

        unordered = re.match(r"^\s*[-*]\s+(.+)$", line)
        ordered = re.match(r"^\s*\d+\.\s+(.+)$", line)
        if unordered or ordered:
            tag = "ul" if unordered else "ol"
            pattern = r"^\s*[-*]\s+(.+)$" if unordered else r"^\s*\d+\.\s+(.+)$"
            output.append(f"<{tag}>")
            while i < len(lines):
                item = re.match(pattern, lines[i])
                if not item:
                    break
                output.append(
                    f"<li>{render_inline(item.group(1), source, source_to_id)}</li>"
                )
                i += 1
            output.append(f"</{tag}>")
            continue

        if line.startswith("> "):
            quote: list[str] = []
            while i < len(lines) and lines[i].startswith("> "):
                quote.append(lines[i][2:])
                i += 1
            output.append(
                f"<blockquote><p>{render_inline(' '.join(quote), source, source_to_id)}</p></blockquote>"
            )
            continue

        paragraph = [line.strip()]
        i += 1
        while i < len(lines) and lines[i].strip():
            candidate = lines[i]
            if (
                re.match(r"^(#{1,3})\s+", candidate)
                or re.match(r"^```", candidate)
                or re.match(r"^\s*[-*]\s+", candidate)
                or re.match(r"^\s*\d+\.\s+", candidate)
                or candidate.startswith("> ")
                or (i + 1 < len(lines) and "|" in candidate and is_table_rule(lines[i + 1]))
            ):
                break
            paragraph.append(candidate.strip())
            i += 1
        output.append(
            f"<p>{render_inline(' '.join(paragraph), source, source_to_id)}</p>"
        )

    if not output or not output[0].startswith("<h1"):
        raise WikiError(f"{source}: article body must start with one H1 heading")
    return "\n".join(output), toc


def validate_registry(registry: dict[str, Any]) -> None:
    if registry.get("schema_version") != 1:
        raise WikiError("wiki-library.json: schema_version must be 1")
    sections = registry.get("sections")
    pages = registry.get("pages")
    history = registry.get("historical_reference")
    coverage = registry.get("repository_coverage")
    if not isinstance(sections, list) or not sections or not all(isinstance(x, str) for x in sections):
        raise WikiError("wiki-library.json: sections must be a non-empty string array")
    if len(set(sections)) != len(sections):
        raise WikiError("wiki-library.json: section names must be unique")
    if not isinstance(pages, list) or not pages:
        raise WikiError("wiki-library.json: pages must be a non-empty array")
    if not isinstance(history, dict) or not all(history.get(x) for x in ("label", "ref", "docs_root")):
        raise WikiError("wiki-library.json: incomplete historical_reference")
    if not isinstance(coverage, dict):
        raise WikiError("wiki-library.json: repository_coverage must be an object")
    scan_roots = coverage.get("scan_roots")
    owners = coverage.get("owners")
    state = coverage.get("state")
    if not isinstance(scan_roots, list) or not scan_roots or not all(
        isinstance(path, str) and path for path in scan_roots
    ):
        raise WikiError("wiki-library.json: repository_coverage.scan_roots must be a non-empty string array")
    if not isinstance(owners, list) or not owners:
        raise WikiError("wiki-library.json: repository_coverage.owners must be a non-empty array")
    if not isinstance(state, dict) or state.get("saga_server") not in {"placeholder", "implemented"}:
        raise WikiError("wiki-library.json: repository_coverage.state.saga_server is invalid")

    ids: set[str] = set()
    sources: set[str] = set()
    required = {"id", "source", "title", "section", "summary", "status", "tags", "source_docs"}
    for index, entry in enumerate(pages):
        if not isinstance(entry, dict) or required - entry.keys():
            raise WikiError(f"wiki-library.json: page {index} has missing fields")
        article_id = entry["id"]
        source = entry["source"]
        if not re.fullmatch(r"[a-z0-9]+(?:-[a-z0-9]+)*", article_id):
            raise WikiError(f"wiki-library.json: invalid id {article_id!r}")
        if article_id in ids or source in sources:
            raise WikiError(f"wiki-library.json: duplicate id or source at page {index}")
        ids.add(article_id)
        sources.add(source)
        if entry["section"] not in sections:
            raise WikiError(f"wiki-library.json: unknown section for {article_id}")
        if entry["status"] not in ALLOWED_STATUS:
            raise WikiError(f"wiki-library.json: invalid status for {article_id}")
        if not source.startswith("library/") or not source.endswith(".md"):
            raise WikiError(f"wiki-library.json: source outside library for {article_id}")
        if not isinstance(entry["tags"], list) or not all(isinstance(x, str) for x in entry["tags"]):
            raise WikiError(f"wiki-library.json: tags must be strings for {article_id}")
        if not isinstance(entry["source_docs"], list) or not all(
            isinstance(x, str) and x.startswith("docs/") for x in entry["source_docs"]
        ):
            raise WikiError(f"wiki-library.json: invalid historical sources for {article_id}")

    owner_paths: set[str] = set()
    for index, owner in enumerate(owners):
        if not isinstance(owner, dict) or set(owner) != {"path", "pages"}:
            raise WikiError(f"wiki-library.json: repository owner {index} is malformed")
        path = owner["path"]
        page_ids = owner["pages"]
        if (
            not isinstance(path, str)
            or path.startswith("/")
            or posixpath.normpath(path) != path
            or path.startswith("../")
        ):
            raise WikiError(f"wiki-library.json: invalid repository owner path {path!r}")
        if path in owner_paths:
            raise WikiError(f"wiki-library.json: duplicate repository owner path {path}")
        owner_paths.add(path)
        if not isinstance(page_ids, list) or not page_ids or not all(
            isinstance(page_id, str) and page_id in ids for page_id in page_ids
        ):
            raise WikiError(f"wiki-library.json: invalid coverage pages for {path}")


def validate_repo_alignment(
    registry: dict[str, Any], articles: list[Article]
) -> list[str]:
    """Validate that the Wiki coverage map still describes current owners."""

    errors: list[str] = []
    coverage = registry["repository_coverage"]
    declared = {owner["path"] for owner in coverage["owners"]}
    discovered: set[str] = set()

    for root_value in coverage["scan_roots"]:
        root = REPO_ROOT / root_value
        if not root.is_dir():
            errors.append(f"repository coverage root is missing: {root_value}")
            continue
        discovered.update(
            path.relative_to(REPO_ROOT).as_posix()
            for path in root.iterdir()
            if path.is_dir()
        )

    for path in sorted(discovered - declared):
        errors.append(f"repository owner has no SagaWiki coverage: {path}")
    for path in sorted(declared - discovered):
        errors.append(f"SagaWiki coverage names a missing repository owner: {path}")

    article_by_id = {article.entry["id"]: article for article in articles}
    server_root = REPO_ROOT / "Engine/Source/Programs/SagaServer"
    server_entrypoints = [
        path
        for path in server_root.rglob("*")
        if path.is_file()
        and path.suffix.lower() in {".c", ".cc", ".cpp", ".cxx"}
        and re.search(r"\bmain\s*\(", path.read_text(encoding="utf-8", errors="ignore"))
    ]
    actual_server_state = "implemented" if server_entrypoints else "placeholder"
    expected_server_state = coverage["state"]["saga_server"]
    if actual_server_state != expected_server_state:
        errors.append(
            "SagaServer repository state changed: registry says "
            f"{expected_server_state}, repository is {actual_server_state}"
        )
    program_article = article_by_id.get("programs-workflows")
    placeholder_statement = "no current executable implementation"
    if program_article:
        has_placeholder_statement = placeholder_statement in program_article.body.lower()
        if actual_server_state == "placeholder" and not has_placeholder_statement:
            errors.append("programs-workflows must state that SagaServer has no current executable implementation")
        if actual_server_state == "implemented" and has_placeholder_statement:
            errors.append("programs-workflows still describes an implemented SagaServer as a placeholder")

    return errors


def load_articles() -> tuple[dict[str, Any], list[Article]]:
    registry = load_json(REGISTRY_PATH)
    validate_registry(registry)
    source_to_id = {entry["source"]: entry["id"] for entry in registry["pages"]}
    articles: list[Article] = []
    for entry in registry["pages"]:
        path = WIKI_ROOT / entry["source"]
        try:
            markdown = path.read_text(encoding="utf-8")
        except FileNotFoundError as exc:
            raise WikiError(f"missing article source: {entry['source']}") from exc
        metadata, body = parse_front_matter(markdown, entry["source"])
        if metadata["title"] != entry["title"]:
            raise WikiError(f"{entry['source']}: title differs from registry")
        if metadata["status"] != entry["status"]:
            raise WikiError(f"{entry['source']}: status differs from registry")
        if metadata["owner"] != "SagaWiki":
            raise WikiError(f"{entry['source']}: owner must be SagaWiki")
        rendered, toc = render_markdown(body, entry["source"], entry["id"], source_to_id)
        articles.append(Article(entry, metadata, markdown, body, rendered, toc))
    return registry, articles


def json_for_html(value: Any) -> str:
    return json.dumps(value, ensure_ascii=False, separators=(",", ":")).replace("</", "<\\/")


def render_index(registry: dict[str, Any], articles: list[Article]) -> str:
    article_data = []
    for article in articles:
        value = dict(article.entry)
        value.update(
            {
                "markdown": article.markdown,
                "html": article.rendered,
                "toc": article.toc,
            }
        )
        article_data.append(value)

    data = {
        "title": registry["title"],
        "sections": registry["sections"],
        "historical_reference": registry["historical_reference"],
        "pages": article_data,
    }
    direct_links = "\n".join(
        f'<li><a href="{html.escape(article.entry["source"], quote=True)}">'
        f'{html.escape(article.entry["title"])}</a></li>'
        for article in articles
    )
    static_links = "\n".join(
        f'<li><a href="#{html.escape(article.entry["id"])}">'
        f'{html.escape(article.entry["title"])}</a> '
        f'<small>{html.escape(article.entry["section"])}</small></li>'
        for article in articles
    )
    return f'''<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="SagaEngine's current, Markdown-backed architecture and contract knowledge base.">
  <title>SagaWiki — SagaEngine knowledge base</title>
  <link rel="stylesheet" href="assets/style.css">
</head>
<body>
<!-- Generated from SagaWiki/library/*.md by scripts/wiki build. Edit Markdown sources. -->
<div class="wiki-shell">
  <header class="topbar">
    <a class="brand" href="#" aria-label="SagaWiki home">SagaWiki</a>
    <label class="search"><span class="sr-only">Search the wiki</span><input id="wiki-search" type="search" placeholder="Search documentation" autocomplete="off"></label>
    <button id="nav-toggle" class="icon-button" type="button" aria-label="Toggle navigation" aria-expanded="false">☰</button>
  </header>
  <aside id="wiki-sidebar" class="sidebar" aria-label="Wiki navigation">
    <nav id="wiki-nav"></nav>
    <footer><a href="library/governance/documentation-selection.md">Documentation policy</a></footer>
  </aside>
  <main id="wiki-main" tabindex="-1">
    <section id="static-home" class="static-home">
      <h1>SagaWiki</h1>
      <p>Current SagaEngine architecture, contracts, workflows, and boundaries.</p>
      <ul class="static-list">{static_links}</ul>
    </section>
    <noscript><section class="noscript"><h2>JavaScript is disabled</h2><p>The Markdown sources remain directly readable:</p><ul>{direct_links}</ul></section></noscript>
  </main>
</div>
<script id="wiki-data" type="application/json">{json_for_html(data)}</script>
<script src="assets/wiki.js"></script>
</body>
</html>
'''


def render_dco_bridge() -> str:
    try:
        source = DCO_SOURCE_PATH.read_text(encoding="utf-8")
    except FileNotFoundError as exc:
        raise WikiError("missing contribution policy source: SagaWiki/policy/contributing-dco.md") from exc
    source = re.sub(r"\A<!--.*?-->\s*", "", source, count=1, flags=re.DOTALL).strip()
    if not source.startswith("## Licensing, DCO, and contribution authority"):
        raise WikiError("contribution policy source has an unexpected heading")
    return "<!-- Generated from SagaWiki/policy/contributing-dco.md by scripts/wiki build. -->\n" + source + "\n"


def git(*args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args], cwd=REPO_ROOT, text=True, capture_output=True, check=False
    )


def git_has_ref(ref: str) -> bool:
    return git("cat-file", "-e", f"{ref}^{{commit}}").returncode == 0


def old_docs_paths(registry: dict[str, Any]) -> tuple[str, set[str]]:
    history = registry["historical_reference"]
    ref = history["ref"]
    docs_root = history["docs_root"]
    if git_has_ref(ref):
        result = git("ls-tree", "-r", "--name-only", ref, "--", docs_root)
        if result.returncode != 0:
            raise WikiError(f"cannot inspect historical reference {ref}: {result.stderr.strip()}")
        return ref, {line for line in result.stdout.splitlines() if line}

    sibling = REPO_ROOT.parent / "SagaEngine 0.0.10" / docs_root
    if sibling.is_dir():
        paths = {
            f"{docs_root}/{path.relative_to(sibling).as_posix()}"
            for path in sibling.rglob("*")
            if path.is_file()
        }
        return str(sibling.parent), paths
    raise WikiError(f"historical reference {ref} is unavailable in Git and no sibling 0.0.10 docs exists")


def selected_old_docs(registry: dict[str, Any]) -> set[str]:
    return {path for entry in registry["pages"] for path in entry["source_docs"]}


def validate_links(articles: list[Article]) -> list[str]:
    errors: list[str] = []
    sources = {article.entry["source"] for article in articles}
    link_re = re.compile(r"\[[^\]]+\]\(([^)]+)\)")
    for article in articles:
        source = article.entry["source"]
        for target in link_re.findall(article.body):
            path = target.split("#", 1)[0]
            if not path or path.startswith(("http://", "https://", "mailto:")):
                continue
            resolved = posixpath.normpath(posixpath.join(posixpath.dirname(source), path))
            if path.endswith(".md") and resolved not in sources:
                errors.append(f"{source}: unresolved Markdown link {target}")
            elif not path.endswith(".md") and not (WIKI_ROOT / resolved).exists():
                errors.append(f"{source}: unresolved local link {target}")
    return errors


def validate_claims(articles: list[Article]) -> list[str]:
    errors: list[str] = []
    for article in articles:
        source = article.entry["source"]
        for number, line in enumerate(article.body.splitlines(), 1):
            normalized = f" {line.lower()} "
            for phrase in CLAIM_PATTERNS:
                if phrase in normalized and not any(word in normalized for word in NEGATION_WORDS):
                    errors.append(f"{source}:{number}: unsupported completion claim: {phrase}")
    return errors


def command_build() -> int:
    registry, articles = load_articles()
    output = render_index(registry, articles)
    INDEX_PATH.write_text(output, encoding="utf-8")
    DCO_BRIDGE_PATH.parent.mkdir(parents=True, exist_ok=True)
    DCO_BRIDGE_PATH.write_text(render_dco_bridge(), encoding="utf-8")
    print(
        f"built {INDEX_PATH.relative_to(REPO_ROOT)} from {len(articles)} Markdown articles "
        "and refreshed the licensing policy bridge"
    )
    return 0


def command_verify() -> int:
    try:
        registry, articles = load_articles()
        errors: list[str] = []

        actual_sources = {
            path.relative_to(WIKI_ROOT).as_posix()
            for path in (WIKI_ROOT / "library").rglob("*.md")
        }
        registered_sources = {article.entry["source"] for article in articles}
        if actual_sources != registered_sources:
            for path in sorted(actual_sources - registered_sources):
                errors.append(f"unregistered Markdown source: {path}")
            for path in sorted(registered_sources - actual_sources):
                errors.append(f"registered source missing from library: {path}")

        retired_content = WIKI_ROOT / "content"
        if retired_content.exists() and any(retired_content.rglob("*")):
            errors.append("retired source tree is not empty: SagaWiki/content")
        pages_root = WIKI_ROOT / "pages"
        page_files = {path for path in pages_root.rglob("*") if path.is_file()} if pages_root.exists() else set()
        unexpected_pages = page_files - {DCO_BRIDGE_PATH}
        for path in sorted(unexpected_pages):
            errors.append(f"retired browsable page remains: {path.relative_to(REPO_ROOT)}")
        if (WIKI_ROOT / "wiki-pages.json").exists():
            errors.append("retired registry still exists: SagaWiki/wiki-pages.json")

        for article in articles:
            filename = Path(article.entry["source"]).name.upper()
            if any(term in filename for term in BANNED_NAME_PARTS):
                errors.append(f"banned historical identity in filename: {article.entry['source']}")

        errors.extend(validate_links(articles))
        errors.extend(validate_claims(articles))
        errors.extend(validate_repo_alignment(registry, articles))

        origin, available = old_docs_paths(registry)
        selected = selected_old_docs(registry)
        for path in sorted(selected - available):
            errors.append(f"historical source is missing at {origin}: {path}")

        if not STYLE_PATH.is_file() or not SCRIPT_PATH.is_file():
            errors.append("reader assets are incomplete")
        expected_bridge = render_dco_bridge()
        if not DCO_BRIDGE_PATH.is_file():
            errors.append("licensing policy bridge is missing; run scripts/wiki build")
        elif DCO_BRIDGE_PATH.read_text(encoding="utf-8") != expected_bridge:
            errors.append("licensing policy bridge is stale; run scripts/wiki build")
        else:
            contributing_path = REPO_ROOT / "CONTRIBUTING.md"
            if not contributing_path.is_file():
                errors.append("CONTRIBUTING.md is missing")
            else:
                contributing = contributing_path.read_text(encoding="utf-8")
                match = re.search(
                    re.escape(DCO_MARKER_BEGIN)
                    + r"\s*(.*?)\s*"
                    + re.escape(DCO_MARKER_END),
                    contributing,
                    flags=re.DOTALL,
                )
                bridge_body = re.sub(
                    r"\A<!--.*?-->\s*", "", expected_bridge, count=1, flags=re.DOTALL
                ).strip()
                if not match or match.group(1).strip() != bridge_body:
                    errors.append("CONTRIBUTING.md DCO section differs from the Wiki policy source")
        expected = render_index(registry, articles)
        if not INDEX_PATH.is_file():
            errors.append("generated SagaWiki/index.html is missing")
        elif INDEX_PATH.read_text(encoding="utf-8") != expected:
            errors.append("SagaWiki/index.html is stale; run scripts/wiki build")
        else:
            index = INDEX_PATH.read_text(encoding="utf-8")
            for required in (
                'href="assets/style.css"',
                'src="assets/wiki.js"',
                'id="wiki-data"',
                "Generated from SagaWiki/library/*.md",
            ):
                if required not in index:
                    errors.append(f"generated index is missing {required}")

        if errors:
            print("SagaWiki verification failed:", file=sys.stderr)
            for error in errors:
                print(f"  ERROR: {error}", file=sys.stderr)
            return 1
        print(
            f"verified {len(articles)} articles, {len(registry['sections'])} areas, "
            f"and {len(selected)} selected historical sources ({origin})"
        )
        return 0
    except WikiError as exc:
        print(f"SagaWiki verification failed: {exc}", file=sys.stderr)
        return 1


def command_old_docs_report() -> int:
    try:
        registry, articles = load_articles()
        origin, available = old_docs_paths(registry)
        selected = selected_old_docs(registry)
        missing = selected - available
        if missing:
            raise WikiError("selected historical sources are missing: " + ", ".join(sorted(missing)))
        print("SagaWiki historical documentation selection")
        print(f"Reference: {registry['historical_reference']['label']} ({origin})")
        print(f"Historical docs files: {len(available)}")
        print(f"Selected source documents: {len(selected)}")
        print(f"Not copied as standalone pages: {len(available) - len(selected)}")
        print(f"Curated current articles: {len(articles)}")
        print("\nSelected inputs by knowledge area:")
        for section in registry["sections"]:
            section_pages = [a for a in articles if a.entry["section"] == section]
            section_sources = {path for a in section_pages for path in a.entry["source_docs"]}
            print(f"  {section}: {len(section_pages)} articles, {len(section_sources)} historical inputs")
        print("\nProtocol: retain only current ownership, source-truth, contract, evidence, workflow, and non-claim knowledge likely to matter in six months.")
        print("Historical plans, milestones, audits, inventories, migration closures, evidence bundles, retired identities, and product strategy remain in Git history.")
        return 0
    except WikiError as exc:
        print(f"old-docs-report failed: {exc}", file=sys.stderr)
        return 1


def usage() -> int:
    print("usage: scripts/wiki {build|verify|old-docs-report}", file=sys.stderr)
    return 2


def main(argv: list[str]) -> int:
    if len(argv) != 2:
        return usage()
    command = argv[1]
    if command == "build":
        try:
            return command_build()
        except WikiError as exc:
            print(f"build failed: {exc}", file=sys.stderr)
            return 1
    if command == "verify":
        return command_verify()
    if command == "old-docs-report":
        return command_old_docs_report()
    return usage()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
